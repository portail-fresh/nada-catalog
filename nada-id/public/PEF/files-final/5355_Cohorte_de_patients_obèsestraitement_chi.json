    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "- identifier les facteurs prédictifs de la réponse à la chirurgie bariatrique pour permettre une meilleure prise en charge - identifier à long terme les complications de la chirurgie bariatrique"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "- to identify predictive factors of response to bariatric surgery in order to improve treatment - to identify long-term complications of bariatric surgery."
        }
