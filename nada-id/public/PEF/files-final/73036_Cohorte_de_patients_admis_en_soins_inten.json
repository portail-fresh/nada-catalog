    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Cette étude a pour objectif d'identifier au sein d'une cohorte de patients admis aux soins intensifs pour des maladies graves ceux qui sont à risque de décès dans l'année suivant la sortie de l'unité de soins intensifs."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "This study aims to identify the risk factors of mortality within a cohort of patients during the year following discharge from the intensive care unit."
        }
      ],
