    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer la valeur pronostique de l’activation de TREM-1 initiale (première mesure recueillie) sur la dégradation clinique des patients hospitalisés pour COVID-19 en service de médecine, des urgences et en réanimation"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the prognostic value of initial TREM-1 activation (first measurement collected) on clinical deterioration in patients hospitalised due to COVID-19 in medical, emergency and intensive care departments"
        }
      ],
