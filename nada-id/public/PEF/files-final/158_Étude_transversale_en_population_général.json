    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Mesurer, en population générale, la variation de la proportion de nourrissons (moins de 27 mois) vaccinés contre l’hépatite B selon le schéma recommandé entre la mesure initiale et les mesures répétées à 1, 2 et 3 ans après l’obtention du remboursement d’InfanrixHexa®"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Measure, in the general population, the variation in the proportion of infants (less than 27 months) vaccinated against hepatitis B according to the recommended plan between the initial measure and the measures repeated 1, 2 and 3 years after obtaining reimbursement of InfanrixHexa®"
        }
      ],
