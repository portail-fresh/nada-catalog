    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Mettre en place une plateforme épidémiologique en vie réelle des lymphomes en France à visée pronostique incluant des données épidémiologiques, cliniques et biologiques avec un suivi prospectif des patients jusqu’à 9 ans."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Set up a real-life epidemiological platform for lymphoma prognosis in France, including epidemiological, clinical and biological data, with prospective follow-up of patients for up to 9 years."
        }
      ],
