      "qualityStatement": {
        "standardsCompliance": {},
        "otherQualityStatement": [
          {
            "lang": "fr",
            "value": "La pression artérielle était mesurée 3 mois à une minute d'intervalle après 5 minutes assis au repose. Un sphygmomanomètre vérifié a été utilisé. Si la moyenne des trois mesures était supérieure à 140 (SBP) ou supérieure à 90 mmHg (DBP), une autre mesure était réalisée après un mois."
          },
          {
            "lang": "en",
            "value": "Blood pressure was measured at 3 months at a one-minute interval following 5 minutes seated and at rest. A verified sphygmomanometer was used. If the average of three measurements was greater than 140 (SBP) or 90 mmHg (DBP), another measurement was taken after one month."
          }
        ]
      },
