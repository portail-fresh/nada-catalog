    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Les objectifs de l'étude était d'estimer les taux d'incidence annuelle de l'hypertension au sein d'une population active et d'identifier les facteurs de risques de l'hypertension."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objectives of the study were to estimate the annual incidence rate of hypertension among the active population and to identify hypertension risk factors."
        }
      ],
