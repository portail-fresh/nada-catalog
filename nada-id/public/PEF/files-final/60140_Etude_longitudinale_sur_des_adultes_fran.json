    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif général : étudier l’impact des conditions de vie et des insertions sociales sur la santé et le recours aux soins. Objectif secondaire : étudier les facteurs territoriaux (contextes sociaux, urbanistiques et offres de services) en lien avec la santé et les recours aux soins."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "General objective: to investigate the impact of living conditions and social integration on health and health care usage. Secondary objective: to investigate territorial factors (social, urban and available services) in relation to health an health care usage."
        }
      ],
