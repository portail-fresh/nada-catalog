    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Etudier des facteurs tels que les connaissances, les attitudes, les croyances vis-à-vis du tabagisme dans un échantillon de la population francilienne et obtenir des informations sur les pratiques du tabagisme dans cette même zone."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To investigate knowledge, attitudes and beliefs towards smoking in a population sample from the Île-de-France region and to obtain information on smoking practices in that area."
        }
      ],
