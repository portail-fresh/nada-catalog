    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer le devenir médico-social de sujets ayant présenté une crise épileptique spontanée et déterminer les facteurs prédictifs de la pharmaco-résistance."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To assess the medical and social outcome of subjects with spontaneous epileptic seizures and to determine drug resistance predictors."
        }
      ],
