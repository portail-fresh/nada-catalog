    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "Recueil des données par les structures de gestion des dépistages chargées de mettre en oeuvre le programme au niveau départemental et de recueillir les informations sur les participants. Les données sur la participation des personnes proviennent du laboratoire de lecture des tests pour le dépistage du cancer colo-rectal et des radiologues pour le dépistage du cancer du sein. Les données cliniques de suivi des personnes dont le dépistage était positif sont recueillies auprès des professionnels de santé qui les ont prises en charge."
        },
        {
          "lang": "en",
          "value": "Data collected by screening management structures in charge of implementing collection programmes at district level and collecting information on participants. Data on individual participation comes from test reading centres for colorectal cancer screening and radiologists for breast cancer screening. Clinical data from monitoring people whose screening was positive are collected from the healthcare professions that are treating them."
        }
      ]
    },
    "geographicalCoverage": {
      "geoDetail": [
        {
          "lang": "fr",
          "value": "Le recueil couvre l'ensemble des départements français (La mayotte devenue département d’outre-mer en 2011 n'est pas encore intégrée dans le programme)"
        },
        {
          "lang": "en",
          "value": "The collection covers all French départements."
        }
      ]
    },
