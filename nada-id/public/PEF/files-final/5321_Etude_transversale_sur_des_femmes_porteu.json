    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Identifier de nombreux loci associés à des modifications du risque tumoral et identifier au sein de nos échantillons des femmes porteuses des allèles associés à une augmentation ou à une diminution du risque tumoral"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To identify the various loci associated with changes in cancer risk and to identify women from our samples with alleles associated with increased or decreased cancer risk."
        }
      ],
