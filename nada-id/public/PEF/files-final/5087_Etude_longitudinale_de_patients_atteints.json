    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "La date d’inclusion correspond à la date de pose de la voie veineuse centrale, chaque patient est suivi pendant 12 mois maximum. Les critères de fin d’observation sont: l’infection liée au cathéter veineux central , l’arrêt de la chimiothérapie intraveineuse, l’ablation du cathéter, le transfert dans un autre hôpital ou le décès"
        },
        {
          "lang": "en",
          "value": "Enrolment date corresponds to date central venous catheter was put in place. Each patient is monitored for a maximum period of 12 months. End of observation criteria are: central venous catheter infection, end of intra-venous chemotherapy, catheter ablation, transfer to another hospital, or death"
        }
      ]
    },
