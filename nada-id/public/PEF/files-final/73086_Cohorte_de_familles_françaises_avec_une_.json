    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif est d’estimer de façon fiable et précise les risques des différentes tumeurs chez les sujets porteurs d’une mutation d’un gène MMR"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The aim is to reliably and accurately determine the risks of different tumours in subjects with MMR gene mutations."
        }
