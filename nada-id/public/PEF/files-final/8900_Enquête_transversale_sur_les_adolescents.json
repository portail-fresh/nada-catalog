    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif de cette étude est d'évaluer les comportements d'adolescents français (de 11 à 17 ans) en termes de bronzage : produits autobronzants, lampe solaire, lits de bronzage artificiel."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objective of this study is to evaluate the behavior of French teenagers (from 11 to 17 years old) regarding tanning : sunless tanning products, sunlamps, artificial tanning beds."
        }
      ],
