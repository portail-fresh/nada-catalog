    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif principal de cette étude était de déterminer l'effet maximal à 1 an d’une intervention multidimensionnelle mise en place lors d’une cure thermale sur le syndrome métabolique."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective of this study was to determine the maximal effect of multidisciplinary management initiated during spa therapy on metabolic syndrome at one year."
        }
      ],
