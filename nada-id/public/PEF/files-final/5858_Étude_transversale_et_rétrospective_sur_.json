    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Sémiologie du TAC Identifier des déficits spécifiques permettant de distinguer des sous-types de trouble de l'acquisition de la coordination (TAC). Définir des marqueurs diagnostiques pour le TAC. et pour chaque typologie"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Semiology of DCD Identify specific deficits to distinguish subtypes of Developmental Coordination Disorder (DCD).. Define diagnostic markers for DCD and for each type"
        }
      ],
