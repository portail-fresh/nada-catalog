    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "Le groupe \"cas\" effectue trois séances par semaine d’un quart d’heure sur une plate-forme Power Plate, encadrées par un coach, à raison de 130 séances pendant 12 mois puis cessent toute activité sportive pendant les six mois suivants afin de vérifier si les bénéfices persistent. Le groupe témoin ne participe à aucune séance."
        },
        {
          "lang": "en",
          "value": "The \"case\" group consists of three 15-minute sessions per week on the Power Plate platform, supervised by a coach, at a rate of 130 sessions over 12 months. All sports activity shall be stopped for the following six months to see if the benefits remain. The control group does not participate in any session."
        }
      ]
    },
