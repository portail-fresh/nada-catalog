      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer la frequence des differents types de gestes et l'intensité de douleur associée Évaluer les différentes approches thérapeutiques préventives et curatives de la douleur liée aux gestes en rhumatologie"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the frequency of the various types of gestures and the intensity of the associated pain Evaluate the various therapeutic preventive and curative approaches for pain linked to gestures in rheumatology"
        }
