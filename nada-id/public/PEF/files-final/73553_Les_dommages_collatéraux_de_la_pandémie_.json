    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire l’évolution de l’acuité visuelle des patients traités par IVT répétées d’anti-angiogéniques lors de l’épidémie liée au COVID-19, entre 09/2019 et 05/2021"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Describe the changes in visual acuity among patients receiving treatment with repeat IVT injections of antiangiogenic agents during the COVID-19 epidemic, between September 2019 and May 2021"
        }
