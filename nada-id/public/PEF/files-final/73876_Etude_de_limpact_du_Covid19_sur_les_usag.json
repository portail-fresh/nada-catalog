    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer l’impact des différents confinements sur les pratiques de consommations de cannabis auprès d’usagers quotidiens, sur les consommations de substances psychoactives et sur l’apparition de symptômes associés (sevrage, douleurs, troubles du sommeil, anxiété, dépression)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the impact of the different lockdowns on cannabis use practices among daily users, psychoactive substance use and the onset of related symptoms (withdrawal, pain, sleep disorders, anxiety, depression)."
        }
      ],
