    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Estimer la durée sous traitement avant tout changement thérapeutique significatif chez des patients diabétiques de type 2 débutant pour la première fois un traitement par exénatide ou insuline."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The primary objective of this study is to estimate the time spent on initial treatment regime before significant treatment change for patients with type 2 diabetes initiating therapy with either insulin or exenatide for the first time."
        }
      ],
