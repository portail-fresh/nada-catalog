    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Estimer et de décrire l’évolution temporelle au cours de l’épidémie des indicateurs suivants dans la patientèle des structures de soins primaires en région AuRA : incidence des cas cliniquement suspects de COVID-19, incidence des cas biologiquement confirmés de COVID-19, caractéristiques cliniques de ces cas."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To estimate and describe, during the epidemics, the temporal evolution of the following indicators in the patient list of the primary care facilities in the Auvergne-Rhône-Alpes French region: incidence of the clinically suspect COVID-19 cases, incidence of the biologically confirmed COVID-19 cases, clinical characteristics of these cases."
        }
      ],
