    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Comprendre l’interaction entre le port du casque et les comportements à risque chez les cyclistes en milieu urbain. Éclairer les décisions en matière de politiques de lutte contre l’insécurité routière."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Understand the relation between the use of the helmet and risk behaviors in urban cyclists. Enlighten the decision concerning road safety politics."
        }
      ],
