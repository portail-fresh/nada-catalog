    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Saisir les pratiques des médecins généralistes face à différentes situations vaccinales."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To assess the presence, extent, and variability of vaccine hesitancy among French general practitioners, in relation to six vaccine situations with suboptimal vaccination coverage. To test factors associated with general practitioners' vaccine recommendations, after verifying that their recommendations were correlated to their own vaccination behavior."
        }
      ],
