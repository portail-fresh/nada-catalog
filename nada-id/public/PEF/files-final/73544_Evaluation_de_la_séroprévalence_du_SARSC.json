    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer la prévalence de l’infection par le SARS-CoV-2 parmi les sujets détenus dans des établissements pénitentiaires franciliens par la mesure du taux anticorps anti SARS-CoV-2 plasmatique"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the prevalence of SARS-CoV-2 infection among prison inmates in detention institutions in the Ile-de-France region, by measuring SARS-CoV-2 antibody levels in plasma"
        }
      ],
