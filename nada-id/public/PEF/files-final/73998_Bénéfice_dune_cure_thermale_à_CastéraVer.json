    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif principal est d'évaluer l’effet d’une cure thermale à Castéra-Verduzan sur l’amélioration fonctionnelle à 6 mois dans la gonarthrose."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective was to evaluate the effect of a spa treatment at Castéra-Verduzan on functional improvement at 6 months in knee osteoarthritis."
        }
      ],
