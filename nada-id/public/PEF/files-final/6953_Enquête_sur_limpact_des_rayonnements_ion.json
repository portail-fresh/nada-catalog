    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer les effets des rayonnements ionisants sur les fonctions reproductives masculines. Évaluer les risques des rayonnements ionisants chez l'homme sur la probabilité de tomber enceinte."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To determine the effects of ionising radiation on male reproductive function. To assess the risks of ionising radiation on humans concerning the probability of pregnancy."
        }
      ],
