    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire dans le temps les symptômes présentés par les patients décrivant une persistance (au-delà de deux mois depuis leur apparition) ou une apparition de symptômes à plus de 3 semaines du début d’une infection par le SARS-CoV-2 (COVID-19) symptomatique prouvée biologiquement."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Describe, over time, the symptoms presented by patients reporting persistent symptoms (more than two months after onset) or onset of symptoms more than 3 weeks after the beginning of symptomatic SARS-CoV-2 (COVID-19) infection evidenced by laboratory tests."
        }
      ],
