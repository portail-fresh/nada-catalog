    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer l'impact d'un programme éducatif par l'information écrite \"Le Guide du Dos\" sur le passage à la chronicité de la lombalgie commune, en plus de l'information orale habituelle délivrée à l'ensemble des sujets lombalgiques."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To assess the impact of an educational programme on the chronic state of common lower back pain, through written information in \"The Back Guide\", as well as the usual verbal information provided to all lower back pain patients."
        }
      ],
