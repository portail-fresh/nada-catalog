    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif de la cohorte est la caractérisation du Polyhandicap (Goupes de sévérité du Polyhandicap, lourdeur des soins, qualité de vie) et la description de l’histoire naturelle du Polyhandicap"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The aim of this cohort is to characterise multiple disabilities (groups according to multiple disability severity, burden of care and quality of life) and to describe the natural history of multiple disabilities."
        }
      ],
