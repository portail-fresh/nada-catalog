    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Constituer une base de données permettant de décrire les hospitalisations conjointes mère-enfant en France, Belgique et Luxembourg. Permettre de tester un certain nombre d'hypothèses cliniques et en particulier des hypothèses sur les facteurs de la santé mentale maternelle et paternelle et les facteurs de risque pour l'enfant."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Build a database for describing joint mother-child hospital admissions in France, Belgium and Luxembourg that may be used to test a number of clinical hypotheses, particularly assumptions about factors of maternal and paternal mental health improvement and risk factors for the child dévelopment and safety."
        }
      ],
