    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Les objectifs de la cohorte sont : -Fournir des caractéristiques épidémiologiques et démographiques -Déterminer la proportion de patients traités/non traités -Déterminer les profils viro-immunologique et thérapeutique -Déterminer les caractéristiques des patients nouvellement diagnostiqués"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objectives of the cohort are: -Provide epidemiological and demographic characteristics -Determine the proportion of treated/untreated patients -Determine viro-immunological and therapeutic profiles -Determine the characteristics of newly diagnosed patients"
        }
      ],
