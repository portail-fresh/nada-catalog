    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif principal est de déterminer l’impact de l’organisation des soins en phase aiguë (prise en charge médicale, paramédicale et thérapeutique) des patients atteints d’un Infarctus Cérébral (IC) sur leur pronostic vital et fonctionnel à court et long terme."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective is to determine the impact of the organization of acute care (medical, paramedical and therapeutic care) for patients with cerebral infarction on short and long term vital and functional prognosis."
        }
      ],
