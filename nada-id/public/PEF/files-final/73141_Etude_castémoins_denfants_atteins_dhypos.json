    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif de l'étude est d'identifier le rôle des expositions professionnelles et environnementales aux perturbateurs endocriniens dans l'hypospadias non génétique isolé"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objective of the study is to identify the impact of occupational and environmental exposure to endocrine-disrupting chemicals on non-genetic, isolated hypospadias."
        }
      ],
