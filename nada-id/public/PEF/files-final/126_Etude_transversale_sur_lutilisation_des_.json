    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire la prise en charge médicamenteuse de la douleur en post-opératoire après une intervention chirurgicale, dans des groupes cibles de patients présentant des risques spécifiques de développer des complications lors de l’utilisation de certaines classes d’antalgiques"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Describe the post-chirurgical drug treatment for pain after a surgical intervention, in target groups of patients having specific risks of developing complications during the use of certain classes of analgesics"
        }
      ],
