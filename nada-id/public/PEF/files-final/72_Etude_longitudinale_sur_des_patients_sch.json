    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer le nombre de patients qui arrêtent leur traitement par olanzapine au cours des 12 premiers mois au sein d’une population souffrant de troubles bipolaires ou de schizophrénie et suivie en ambulatoire"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The primary objective of this study is to assess the proportion of schizophrenic patients and the proportion of bipolar patients who discontinued olanzapine within 12 months of treatment in outpatient, ambulatory or community settings."
        }
      ],
