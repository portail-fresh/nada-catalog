    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Mesurer l’effet de l’accompagnement personnalisésur la participation au dépistage Identifier les mécanismes psychologiques leviers potentiels de l’action de l’accompagnateur Mesurer l’effet d’un programme d’accompagnement sur la réduction des inégalités sociales Évaluer le rapport coût-efficacité du programme"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Measure the effect of personalized support on participation in screening Identify the psychological mechanisms that can act as levers for the support team's action Measure the effect of a support program on reducing social inequalities Evaluate the program's cost-effectiveness."
        }
      ],
