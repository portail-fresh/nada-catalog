    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Nous avons effectué un sondage auprès d'une population de patients LIS pour décrire la qualité de vie des patients LIS sur une période de 6 ans et de déterminer les facteurs prédictifs potentiels d'un changement de la qualité de vie"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "We performed a survey of a population of LIS patients to describe the course of the QoL of LIS patients over a 6-year period and to determine the potential predictive factors of QoL changes over time."
        }
      ],
