    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Définir, sur le plan psychopathologique, neurologique et pharmacocinétique, les facteurs prédictifs de développer une addiction comportementale (AC) secondaire au traitement dopaminergique, associée ou non à un syndrome de dysrégulation dopaminergique (SDD), chez des malades de Parkinson."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To define psychopathologically, neurologically and pharmacokinetically the predictive factors for the development of behavioural addiction (BA) secondary to dopaminergic treatment, associated or not with dopamine dysregulation syndrome (DDS), in Parkinson's patients."
        }
      ],
