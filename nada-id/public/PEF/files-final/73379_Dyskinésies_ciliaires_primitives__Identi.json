    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif principal est d’identifier dans une grande cohorte de patients DCP, des facteurs prédictifs précoces de sévérité afin d’améliorer la prise en charge personnalisée des patients."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective is to identify in a large cohort of PCD patients, early predictors of severity in order to improve personalized patient management."
        }
      ],
