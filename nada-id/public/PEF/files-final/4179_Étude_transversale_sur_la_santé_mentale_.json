    "dataTypes": {
      "clinicalDataDetails": {
        "lang": "fr",
        "value": "Evaluation de la santé mentale (Mini International Neuropsychiatric Interview), évaluation de la personnalité, niveau d’abstraction du détenu (via échelle CGI), entretien qualitatif semi-directif sur la perception par le détenu de son état psycho logique"
      },
      "isDataInBiobank": false
    },
    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "Deux cliniciens (un psychiatre et un psychologue clinicien) rencontrent ensemble la personne interrogée. Le psychologue conduit un entretien structuré conformément aux directives du MINI (Mini International Neuropsychiatric Interview). Le psychiatre poursuit par un entretien libre avec la personne détenue (données personnelles, familiales et judiciaires avant l’incarcération). Puis les cliniciens donnent chacun, indépendamment l’un de l’autre, un (ou plusieurs) diagnostic(s) (issus du MINI et de la clinique) ; dans un second temps, ils se concertent et proposent un (ou plusieurs) diagnostic(s) dit(s) consensuel(s). Ils évaluent également séparément puis consensuellement la gravité de l’état de la personne (échelle de gravité CGI) et de ses antécédents."
        },
        {
          "lang": "en",
          "value": "Two clinicians (a psychiatrist and a clinical psychologist) meet with the interviewee together. The psychologist conducts a structured interview in accordance with MINI (Mini International Neuropsychiatric Interview) guidelines. The psychiatrist then conducts an open-ended interview with the prisoner (covering personal, family and legal information prior to imprisonment). The clinicians then each independently make one (or more) diagnosis(es) (based on the MINI and clinical findings). in a second stage, they consult each other and propose one (or more) consensus diagnosis(es). They also assess separately and then consensually the severity of the person's condition (CGI severity scale) and their history."
        }
      ]
    },
    "geographicalCoverage": {
      "geoDetail": [
        {
          "lang": "fr",
          "value": "3 établissements sélectionnés (Moulins Yzeure, Val de Reuil et St Martin de Ré)"
        },
        {
          "lang": "en",
          "value": "Three establishments selected (Moulins Yzeure, Val de Reuil and St Martin de Ré)"
        }
      ]
    },
