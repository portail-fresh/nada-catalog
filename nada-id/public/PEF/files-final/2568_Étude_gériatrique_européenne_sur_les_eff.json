    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer les effets sur la santé des principaux polluants de l’air intérieur et les conditions climatiques chez les personnes âgées de plus de 65 ans vivant dans des maisons de retraite."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the effects on health of the main indoor air pollutants and the climatic conditions in the elderly over the age of 65 years living in retirement homes."
        }
