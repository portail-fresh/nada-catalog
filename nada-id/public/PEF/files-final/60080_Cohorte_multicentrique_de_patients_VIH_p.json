    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif général : étudier la progression spontanée de la maladie VIH et de la réponse au traitement des sujets non hémophiles (SEROCO) ou hémophiles (HEMOCO). Rôle pronostique des marqueurs, en particulier CD4, ARN-VIH, et ADN-VIH."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "General objective: to investigate spontaneous HIV disease progression and the treatment response of haemophiliac (HEMOCO) or non-haemophiliac (SEROCO) subjects. The prognostic role of markers, in particular CD4, HIV-RNA and HIV-DNA."
        }
      ],
