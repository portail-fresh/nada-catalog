    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif principal de cette cohorte avec biocollections est de pouvoir décrire l’épidémiologie des complications médicales survenant au cours de l’hospitalisation en réanimation"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The primary objective of this cohort with biocollections is to describe the epidemiology of medical complications arising during hospitalisation in an intensive care unit"
        }
      ],
