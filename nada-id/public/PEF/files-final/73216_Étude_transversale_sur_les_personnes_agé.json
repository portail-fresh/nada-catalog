    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "les objectifs de cette étude étaient d'examiner si la prise de Benzodiazépines a été associés à des chutes récurrentes tout en tenant compte de l'effet des facteurs de confusion potentiels"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "the objectives of this study were to examine whether benzodiazepine use has been associated with recurrent falls while taking into account the effect of potential confounders"
        }
      ],
