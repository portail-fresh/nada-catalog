    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif général : rechercher des facteurs génétiques et environnementaux et de leurs intéractions pour l'asthme, ainsi que pour les phénotypes associés hyper-réactivité bronchique et atopie."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "General objective: to investigate genetic and environmental factors and their impact on asthma, as well as phenotypes associated with bronchial hyperresponsiveness and atopy."
        }
      ],
