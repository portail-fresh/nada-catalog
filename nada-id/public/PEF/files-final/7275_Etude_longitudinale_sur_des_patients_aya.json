    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer la sécurité et évaluer les effets de la bioprothèse en termes de survie, de gêne fonctionnelle, de qualité de vie et de paramètres hémodynamiques."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To determine the safety and evaluate the effects of the bioprosthesis in terms of survival, functional discomfort, quality of life and haemodynamic parameters."
        }
