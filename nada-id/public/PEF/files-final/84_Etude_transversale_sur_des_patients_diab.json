    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "décrire les effets sur la glycémie à jeun à 1 mois des principales modalités d’éducation des patients diabétiques de type 2 lors de l’instauration d’une insulinothérapie en médecine générale"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "describe the effects on the fasting glucose at 1 month for main methods of education of type-2 diabetes patients during the initiation of insulin therapy in general practice"
        }
