    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Mettre une collection d'ADN et de cellules de patients atteints de sclérose en plaques et de leurs apparentés à la disposition de la communauté scientifique (toute équipe en faisant la demande)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To make a collection of DNA and cells from patients with multiple sclerosis and their relatives that can be accessed by the scientific community (any team on request)."
        }
      ],
