    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Mesurer des indicateurs clés sur les opinions, attitudes et comportements en matière de santé de populations sourdes, malentendantes et/ou ayant des troubles de l'audition et, tant que faire se peut, les comparer à ceux de la population générale."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To measure indicators on opinions, attitudes towards health and health behaviors of people living with hearing impairment, and if possible, to compare them with indicators in the general population."
        }
      ],
