    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer l'incidence des crises d’épilepsies dans la population réunionnaise. Déterminer les facteurs de risques spécifiques à la Réunion chez les patients épileptiques."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To evaluate the incidence of seizures in Réunion's population. To determine the risk factors specific to Réunion among epileptic patients"
        }
