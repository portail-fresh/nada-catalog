    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Cette étude visait à évaluer la prévalence et les facteurs de risque d'infection HPV chez une cohorte de jeunes femmes françaises sexuellement actives éligibles pour la vaccination anti HPV"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objective of this study was to assess the prevalence and risk factors for HPV infection in a cohort of sexually active young French women eligible for HPV vaccination"
        }
      ],
