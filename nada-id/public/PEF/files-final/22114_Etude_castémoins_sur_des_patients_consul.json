    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Analyser les facteurs de risque de dermatite séborrhéique et les facteurs de risque de poussée. Évaluer le retentissement de la dermatite séborrhéique sur la qualité de vie."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To analyse risk factors for seborrheic dermatitis and risk factors for a flare-ups. To assess the impact of seborrheic dermatitis on quality of life."
        }
      ],
