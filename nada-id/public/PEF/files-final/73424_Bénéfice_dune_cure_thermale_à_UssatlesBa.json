    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif principal est d'évaluer l’évolution de l’incapacité fonctionnelle due à une lombalgie chronique, 6 mois après une cure thermale à Ussat-les-Bains."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective is to evaluate the evolution of functional disability due to chronic low back pain, 6 months after a spa treatment at Ussat-les-Bains."
        }
      ],
