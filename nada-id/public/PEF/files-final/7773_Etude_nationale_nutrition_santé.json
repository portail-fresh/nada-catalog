    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire la consommation alimentaire, l’activité physique et le statut nutritionnel des enfants et des adultes à partir d’un échantillon représentatif de la population vivant en France métropolitaine en 2006-2007."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe food consumption, physical activity and nutrition of children and adults from a representative sample of the population living in France between 2006-2007."
        }
      ],
