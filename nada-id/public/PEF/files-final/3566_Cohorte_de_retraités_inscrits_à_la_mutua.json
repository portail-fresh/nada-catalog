    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Étude de la maladie liée à l'âge avec un intérêt plus particulier pour la maladie d’Alzheimer et des syndromes apparentés. Étudier le recours aux soins et aux aides sociales Comparer avec le milieu urbain (3C et PAQUID)"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Study of the disease, especially in association with age. Study health care use and social measures for Alzheimers disease and similar syndromes. Compare with the urban areas (3C and PAQUID)"
        }
      ],
