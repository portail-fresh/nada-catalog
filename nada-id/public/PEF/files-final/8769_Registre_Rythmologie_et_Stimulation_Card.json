    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Recueil de toutes les implantations de défibrillateurs et de système de resynchronisation en France, actif depuis mars 2007 ; Il concerne également tous les autres stimulateurs cardiaques dits « conventionnels » (simple et double chambre)"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Collection of all implantable cardioverter-defibrillator and resynchronisation system data in France, active since March 2007. This also includes other \"conventional\" pacemakers (single and double chamber)."
        }
      ],
