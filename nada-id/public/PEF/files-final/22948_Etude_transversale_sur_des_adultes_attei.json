    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer le taux de diagnostic annuel de thrombose veineuse superficielle symptomatique des membres inférieurs dans le cadre des soins de santé primaire. Evaluer la proportion de cas de thrombose veineuse superficielle avec simultanément une thrombose veineuse profonde et/ou une embolie pulmonaire symptomatique."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To evaluate the annual diagnosis rate of symptomatic superficial venous thrombosis of the lower limbs in the primary health-care setting. To evaluate the proportion of superficial venous thrombosis cases that occur simultaneously with symptomatic pulmonary embolism and/or deep vein thrombosis"
        }
      ],
