    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Coordonner la collecte des informations portant sur les patients fréquentant les consultations mémoire du CM2R de Lyon, et concernant la clinique, la neuropsychologie, les thérapeutiques, les coûts hospitaliers, la banque Neurobiotec, les données socio-démographiques, la biologie, la neuroimagerie et la neuroanatomo-pathologie."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To coordinate the collection of information on the patients frequenting the memory consultation clinics of the Lyon CMRR, and that concerning clinical practice, neuropsychology, treatments, hospital costs, the Neurobiotec bank, sociodemographic data, biology, neuroimaging and neuroanatomy and pathology"
        }
      ],
