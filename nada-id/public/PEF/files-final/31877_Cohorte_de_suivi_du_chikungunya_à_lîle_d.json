    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Connaître les connaissances, attitudes, comportements et pratiques de la population réunionnaise sur la maladie et sa prévention; ses facteurs de risque ; son évolution à moyen et long terme; servir de base d'inclusion pour des études ancillaires étudiant l'exposition au virus du chikungunya."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To determine the knowledge, attitudes, behaviours and practices of the population in Réunion regarding the disease and its prevention; risk factors, medium- and long-term development; to be included in ancillary student studies on Chikungunya virus exposure."
        }
      ],
