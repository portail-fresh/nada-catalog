    "dataTypes": {
      "clinicalDataDetails": [
        {
          "lang": "fr",
          "value": "Psoriasis (âge au moment de l'acquisition, caractéristiques cliniques, rhumatismes, traitements reçus, antécédents familiaux), maladies cardiovasculaires et facteurs de risque (hypertension, consommation de tabac, évènement cardiovasculaire majeur dont angine de poitrine, infarctus de myocarde et accident cérébrovasculaire), antécédents familiaux d'évènements cardiovasculaires majeurs (dont infarctus de myocarde, mort cardiaque et AVC), maladies métaboliques (poids, indice de masse corporelle, circonférence de la taille, diabète et dyslipidémie)."
        },
        {
          "lang": "en",
          "value": "data on psoriasis (age at onset, clinical characteristics, rheumatism, historyof treatments, family history including first-degree relatives only); cardiovascular risk factors and diseases (i.e. hypertension, current smoking, major cardiovascular event (including angina pectoris, myocardial infarction and stroke) and family history of major cardiovascular event (including myocardial infarction, cardiac death and stroke in first-degree relatives); and metabolic diseases (i.e. weight, BMI, waist circumference, diabetes and dyslipidaemia)."
        }
      ],
      "isDataInBiobank": false
    },
    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "Un protocole d'enquête a été élaboré pour cette étude prenant la forme d'un formulaire rempli par le médecin lors d'une consultation."
        },
        {
          "lang": "en",
          "value": "A protocol for evaluation (comprising 38 items) was implemented with a case report form especially created for the study."
        }
      ]
    },
