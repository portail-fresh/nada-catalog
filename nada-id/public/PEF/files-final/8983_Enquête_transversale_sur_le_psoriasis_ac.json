    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif est d'évaluer l'existence d'une corrélation entre l'acquisition du psoriasis durant l'enfance et la fréquence de comorbidités cardiovasculaires et métaboliques dans la vie adulte."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective of this study is to assess the correlation between childhood-onset psoriasis and the frequency of cardiovascular and metabolic comordibities during adulthood."
        }
      ],
