    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif primaire est de décrire la survie globale à 5 ans après l’initiation du pembrolizumab chez des patients atteints de mélanome avancé (non résécable ou métastatique)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The primary objective is to describe 5-year overall survival after initiation of pembrolizumab in patients with advanced melanoma (unresectable or metastatic)."
        }
      ],
