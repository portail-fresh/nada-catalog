    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Les objectifs de cette étude étaient d'évaluer la prévalence du phénomène de Raynaud à Nantes , et étudier la relation entre la prévalence et le climat froid."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objectives of this study were to evaluate the prevalence of Raynaud's phenomenon in Nantes and study the relationship between its prevalence and the cold climate."
        }
      ],
