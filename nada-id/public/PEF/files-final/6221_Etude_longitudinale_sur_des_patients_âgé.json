    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Tester l'hypothèse selon laquelle l'évaluation gériatrique standardisée constitue un facteur pronostique dans la survenue de complications post opératoires dans les 30 jours suivants une chirurgie d'exérèse pour cancer bronchique"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To test the hypothesis that standardised geriatric assessment is a prognostic factor for post-operative complications within 30 days following surgical resection for lung cancer."
        }
      ],
