    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif général : mettre en évidence des marqueurs prédictifs de la survenue du rejet chronique de greffe pulmonaire par des approches d'immunologie, de transcriptomique, de génomique, de protéome appliquées au prélèvements sanguins et in situ réalisés sur les patients de la cohorte."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Highlight preditive factors of the occurrence of chronic lung allograft dysfunction by immunologic, transcriptomics, genomics and proteomics approaches applied to blood and in situ samples performed on patients."
        }
      ],
