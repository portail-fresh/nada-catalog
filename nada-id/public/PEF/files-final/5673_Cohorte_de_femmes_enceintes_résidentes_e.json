    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Étudier en Guadeloupe l’impact sur la grossesse (prématurité, retard de croissance intra-utérin, malformations congénitales) et le développement neurologique postnatal, de l’exposition (prénatale et pendant l’enfance) aux polluants organochlores (principalement chlordécone)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To study the impact on pregnancy (prematurity, delayed intrauterine growth, birth defects) and postnatal neurological development from exposure (prenatal and childhood) to organochlorine pollutants (mainly chlordecone) in Guadeloupe."
        }
      ],
