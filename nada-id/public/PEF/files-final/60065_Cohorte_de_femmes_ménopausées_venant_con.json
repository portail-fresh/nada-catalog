    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Étudier l’impact des estrogènes trans-dermiques et des autres traitements de la ménopause sur le risque de récidive de thrombose veineuse."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To investigate the impact of transdermal oestrogens and other menopause treatments on the risk of recurrent venous thrombosis."
        }
      ],
