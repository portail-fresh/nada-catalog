    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "L'enquête se déroulait de jour, auprès des utilisateurs des services du type hébergement, distribution de nourriture et de repas chauds, y compris itinérants. Environ 6 personnes par site étaient tirées et se voyaient proposer l'enquête. Il était toujours précisé que l'enquête était facultative, totalement anonyme et confidentielle."
        },
        {
          "lang": "en",
          "value": "The survey was carried out during the day with users of shelter, food and hot meal distribution services, including itinerant individuals. Approximately 6 people per site were selected to be surveyed. It was always stated that the survey was optional, totally anonymous and confidential."
        }
      ]
    },
    "geographicalCoverage": {
      "geoDetail": [
        {
          "lang": "fr",
          "value": "Région Ile-de-France : centres de Paris intra-muros et centres de banlieue (centre d'accueil et de soins hospitaliers de Nanterre et centre Corentin Celton d'Issy-les-Moulineaux)."
        },
        {
          "lang": "en",
          "value": "Île-de-France region: centres within Paris city limits and suburban centres (Nanterre shelter and hospital care centre and Corentin Celton centre in Issy-les-Moulineaux)."
        }
      ]
    },
