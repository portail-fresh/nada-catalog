    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif est d'étudier l'utilisation de différentes insuline (durée de l'exposition, doses administrées) et son possible lien avec l'augmentation du risque de cancer du sein."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The aim is to assess the possible relation between using individual insulins (duration of exposure, administered dosage) and increased breast cancer risk."
        }
      ],
