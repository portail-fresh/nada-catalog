    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Etudier la prévalence et le profil sérologique (présence d’anticorps et donc du contact avec le SARS COV2) chez des résidents et des personnels soignants d’EHPAD asymptomatiques (sans symptômes évoquant une infection en cours à COVID 19), ainsi que celui des personnels soignants asymptomatiques des établissements sanitaires du groupe UNIVI."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To study the prevalence and serological profile (presence of antibodies and therefore of contact with SARS COV2) in asymptomatic EHPAD residents and nursing staff (without symptoms suggestive of ongoing COVID 19 infection), as well as that of asymptomatic nursing staff in UNIVI group health facilities."
        }
      ],
