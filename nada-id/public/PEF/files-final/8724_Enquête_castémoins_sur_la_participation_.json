    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif de cette enquête est d'étudier de nombreux déterminants de l'abandon d'activité sportive organisée chez des adolescents français, afin de déterminer les facteurs distaux et proximaux de l'abandon."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objective of this survey is to study many determinants of discontinuation of an organised sports activity in French adolescents, in order to determine the distal and proximal factors of the discontinuation."
        }
      ],
