    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Créer et valider le questionnaire IBHQ (Impact of Bronchiolitis Hospitalization Questionnaire) destiné à évaluer de manière spécifique l’impact sur les parents de l’hospitalisation de leur nourrisson pour bronchiolite. Décrire l’impact sur les parents de l’hospitalisation de leur nourrisson pour bronchiolite."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Create and validate the Impact of Bronchiolitis Hospitalization Questionnaire (IBHQ) intended to specifically evaluate the impact on parents of their infants being hospitalized for bronchiolitis. Describe the impact on parents of their infants being hospitalized for bronchiolitis."
        }
      ],
