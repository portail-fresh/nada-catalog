    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Comparer les concentrations plasmatiques de l'hormone folliculo-stimulante (FSH) mesurées à l'âge postnatal de 3 mois entre les trois groupes de nouveau-nés appariés (sur l'âge gestationnel à la naissance, l'âge postnatal et l'insuffisance respiratoire)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To compare the follicle stimulating hormone (FSH) plasma concentrations measured at the postnatal age of 3 months between the three matched (on gestational age at birth, postnatal age and respiratory failure) newborn infants groups"
        }
      ],
