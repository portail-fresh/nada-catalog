      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Effectuer des recherches sur la dissection d'une artère cervicale et les accidents ischémiques cérébraux chez les jeunes adultes, et en particulier sur les facteurs de risque, le traitement et les prédicateurs de résultats"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To conduct research on cervical artery dissection and strokes in young adults, and in particular the risk factors, treatment and predictors of results"
        }
