    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Analyser les différences régionales entre la Guadeloupe et la Réunion sur les pratiques contraceptives avant et après un avortement."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To analyse the regional differences between Guadeloupe and La Réunion in terms of contraceptive practice before and after abortion."
        }
