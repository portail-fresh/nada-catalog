    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Étudier les données neuropathologiques dans les maladies neurologiques avec troubles cognitifs avec constitution d'une banque de données standardisées (clinique, biologique, neurologique, imagerie, génétique, médicosociaux) par un suivi longitudinal de malades Alzheimer jeunes et constitution d'une banque tissulaire par prélèvement cérébral post-mortem."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To study neuropathological data in neurological disorders with cognitive impairment."
        }
      ],
