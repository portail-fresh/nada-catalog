    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Cette étude a pour objectif principal d’évaluer les conséquences économiques et sociales des thérapies anticancéreuses orales chez des patientes atteintes d’un cancer du sein avancé ou métastatique surexprimant Her2"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective of this study is to assess the economic and social consequences of oral cancer therapies in patients with advanced or metastatic breast cancer overexpressing Her2"
        }
      ],
