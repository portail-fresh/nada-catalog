    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif général : étudier les déterminants familiaux (génétiques et environnementaux) des facteurs et/ou indicateurs de risque cardiovasculaire en utilisant le modèle de la famille nucléaire. Les 2 aspects, transversal et longitudinal, sont abordés grâce à des designs spécifiques."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "study the family determinants (genetic and environmental) of cardiovascular risk indicators and/or factors by using the model of the nuclear family. The 2 aspects, cross-sectional and longitudinal, are broached through specific designs."
        }
      ],
