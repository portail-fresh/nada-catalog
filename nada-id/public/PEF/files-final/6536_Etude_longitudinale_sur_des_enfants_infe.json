    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire l’évolution à court, moyen et long terme des enfants infectés par le VIH1 ou le VIH2 et pris en charge avant l’âge de 15 ans."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Study the conditions of access to early treatment of children infected with HIV, their management on the long-term, and impact on growth, clinical and immunovirological prognosis, adherence to treatment, living conditions, risk-taking in adolescence analyzed with the new."
        }
      ],
