    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer la qualité de vie au long terme (à 1 et 2 ans) des patients d’hématologie ayant survécu à une admission en réanimation, et de modéliser l’évolution de celle-ci depuis la sortie de réanimation."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To assess long-term quality of life (at 1 and 2 years) for haematology patients that survived ICU admission and to model the outcome of this following discharge from ICU."
        }
      ],
