    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif principal est d’évaluer l’efficacité comparative à 6 mois d’une cure thermale à Saint-Lary Soulan sur l’incapacité fonctionnelle et la douleur (MCII : Minimal Clinical Important Improvement) dans la gonarthrose par rapport au groupe témoin de l’essai clinique randomisé multicentrique Thermarthrose, recevant des soins standards."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The primary objective is to evaluate the comparative efficacy at 6 months of a spa treatment in Saint-Lary Soulan on functional disability and pain (MCII: Minimal Clinical Important Improvement) in knee osteoarthritis compared to the control group in the Thermarthrose multicentre randomised clinical trial, receiving standard care."
        }
      ],
