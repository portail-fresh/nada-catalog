    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire l’épidémiologie du purpura thrombopénique immunologique et de l'anémie hémolytique auto-immune, leur prise en charge, et fournir des RWE sur les traitements de ces maladies en termes d'efficacité et de sécurité"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe the epidemiology of immune thrombocytopenic purpura (ITP) and of autoimmune hemolytic anemia (AIHA), assess their mangement and provide RWE of their treatments in terms of effectiveness and safety"
        }
      ],
