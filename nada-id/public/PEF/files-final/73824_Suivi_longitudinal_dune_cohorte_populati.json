    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Étudier l’évolution au cours du temps de la réponse humorale spécifique générée par l’infection par le virus SARS-CoV-2 dans différents échantillons biologiques chez des sujets dans différents groupes d’âge."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Study the changes over time of the specific humoral response generated by SARS-CoV-2 virus infection in different biological specimens from subjects in different age groups."
        }
      ],
