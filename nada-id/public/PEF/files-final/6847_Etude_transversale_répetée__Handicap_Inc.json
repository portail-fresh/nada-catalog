    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "Recueil des données auprès des personnes handicapées en institution conduite avec un premier passage en 1998 et un second en 2000; auprès des ménages, qui a été précédée d'une phase de filtrage réalisée en 1999 et suivie d'un premier passage en 1999 et d'un second en 2001; auprès de la population handicapée en milieu carcéral, réalisée en 2001. Les questionnaires ont été remplis par l’enquêteur avec la personne sélectionnée pour l’enquête ou, en cas d’inaptitude, avec un soignant, un éducateur ou un proche."
        },
        {
          "lang": "en",
          "value": "Data are collected from disabled people in institutions with the first round in 1998 and a second round in 2000; from households preceded by a screening phase in 1999 with the first round in 1999 and subsequent round in 2001; from the disabled population in a custodial setting, which was carried out in 2001. Questionnaires are completed by the researcher with the person selected for the survey or, in the case of incapacity, with a caregiver, educator or someone close to them."
        }
      ]
    },
    "geographicalCoverage": {
      "geoDetail": [
        {
          "lang": "fr",
          "value": "France (1 918 établissements pour personnes âgées, foyers pour handicapés jeunes et adultes et institutions psychiatriques)"
        },
        {
          "lang": "en",
          "value": "France (1,918 nursing homes, homes for disabled adults and young people, as well as psychiatric institutions)"
        }
