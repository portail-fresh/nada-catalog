      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer les performances du Fibroscan dans le diagnostic de la fibrose et de la cirrhose hépatiques comparativement à la ponction-biopsie hépatique."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To evaluate the Fibroscan's performance in the diagnosis of hepatic fibrosis and cirrhosis compared to hepatic needle biopsy."
