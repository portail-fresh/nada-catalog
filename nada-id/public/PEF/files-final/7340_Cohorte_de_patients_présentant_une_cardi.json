    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Estimer la prévalence de la maladie de Fabry dans une population d’hommes et de femmes souffrant de cardiomyopathie hypertrophique (CMH) d’allure primitive."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To estimate the prevalence of Fabry disease in a population of men and women with hypertrophic cardiomyopathy (HCM) consistent with primary cardiomyopathy."
        }
      ],
