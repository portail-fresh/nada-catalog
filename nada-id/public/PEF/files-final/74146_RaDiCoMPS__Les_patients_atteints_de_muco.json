    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif principal de la cohorte RaDiCo-MPS est de caractériser l’épidémiologie et l’histoire naturelle des MPS en construisant une collecte rétrospective et prospective de données phénotypiques étendues de patients français atteints de MPS."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The primary objective of the RaDiCo-MPS cohort is to characterize the epidemiology and natural history of MPS diseases by building a retrospective and prospective collection of extensive phenotypic data from French MPS patients."
        }
      ],
