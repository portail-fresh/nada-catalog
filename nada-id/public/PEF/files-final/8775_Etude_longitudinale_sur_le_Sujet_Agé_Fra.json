    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer les facteurs influençant le devenir des malades âgés à partir des résultats d’une EGS réalisée dans la première semaine d’hospitalisation. Décrire et de comparer les filières de soins intra-hospitalières."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To determine the factors influencing the outcome for elderly sick people from the results of standard geriatric assessments (EGS) during the first week of hospitalisation. To describe and compare intra-hospital healthcare networks."
        }
      ],
