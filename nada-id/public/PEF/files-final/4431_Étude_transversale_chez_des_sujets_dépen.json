    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer les propriétés psychométriques de l'échelle d'évaluation de l'alexithymie (OAS). Evaluer la cohérence des différentes échelles de mesure de l'alexithymie (OAS, TAS-20 et BVAQ-B). Etudier la relation entre l'alexithymie et la dépendance au cannabis."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To evaluate the psychometric properties of the Observer Alexithymia Scale (OAS). To evaluate the consistency of different alexithymia measurement scales (OAS, TAS-20 and BVAQ-B). To study the relationship between alexithymia and cannabis dependence."
        }
      ],
