    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif principal de cette étude était d’estimer l’incidence des cancers chez ces patients ; l’objectif secondaire était de préciser leurs facteurs de prédisposition aux cancers."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective of this study was to estimate the incidence of cancers in these patients; the secondary objective was to specify their cancer predisposition factors."
        }
