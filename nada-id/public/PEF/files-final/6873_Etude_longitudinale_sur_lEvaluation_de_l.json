    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer pour la première fois de manière prospective, la prévalence et les facteurs de risque de complications systémiques et de lymphomes au cours du syndrome de SJögren primitif."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To prospectively determine for the first time the prevalence and risk factors for systemic complications and lymphoma in primary Sjögren's syndrome."
        }
      ],
