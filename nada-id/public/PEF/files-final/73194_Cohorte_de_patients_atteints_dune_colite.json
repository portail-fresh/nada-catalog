    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif est de décrire les caractéristiques d'une cohorte de patients atteints de colite microscopique (MC; lymphocytaire (LC) ou de collagène (CC) colites) et de les comparer avec les patients souffrant de troubles fonctionnels de l'intestin avec diarrhée"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The aim is to describe the characteristics of a cohort of patients with microscopic colitis (MC; lymphocytic colitis (LC) or collagenous colitis (CC)) and to compare them with patients suffering from functional bowel disorders with diarrhoea."
        }
      ],
