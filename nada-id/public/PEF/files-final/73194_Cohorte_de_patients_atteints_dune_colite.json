    "dataTypes": {
      "clinicalDataDetails": [
        {
          "lang": "fr",
          "value": "Histoire personnelle de l'appendicectomie, cholécystectomie, IMC , le nombre de selles quotidiennes (3-4, 5-9, 10 ou plus), l'existence de selles nocturnes, douleurs abdominale. Date du diagnostic, Habitudes Tabacs, perte de poids. Médicaments"
        },
        {
          "lang": "en",
          "value": "Personal history of appendectomy; cholecystectomy; BMI, number of daily bowel movements (3-4, 5-9, 10 or more); presence of nocturnal stools and abdominal pain. Date of diagnosis; smoking habits; weight loss. Medication."
        }
      ],
      "biologicalDataDetails": [
        {
          "lang": "fr",
          "value": "La protéine C réactive, de potassium sérique, l'hémoglobine, les leucocytes et nombre d'éosinophiles, et l'hormone stimulant la thyroïde"
        },
        {
          "lang": "en",
          "value": "C-reactive protein; serum potassium; haemoglobin; leukocytes and eosinophils; thyroid stimulating hormone."
        }
      ],
