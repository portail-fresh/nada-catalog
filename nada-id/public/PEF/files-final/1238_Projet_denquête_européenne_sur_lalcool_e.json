    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Rassembler des données comparables sur l'usage de l'alcool, du tabac et d'autres drogues illicites parmi la population adolescente âgée de 15-16 ans dans autant de pays européens que possible, en utilisant une méthodologie standardisée. Suivre et comparer les tendances des usages dans les pays européens."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Collect comparable data on the use of alcohol, tobacco and other illicit drugs among the adolescent population aged 15-16 years in as many European countries as possible, using a standardized methodology. Monitor and compare usage trends in European countries."
        }
      ],
