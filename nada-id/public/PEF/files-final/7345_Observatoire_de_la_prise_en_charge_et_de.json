    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer les composantes du risque d’insuffisance cardiaque chez des patients hypertendus vus en médecine générale. Comparer les estimations par le médecin du risque d’insuffisance cardiaque et du risque cardiovasculaire global par rapport au risque calculé par des échelles validées. Évaluer la concordance entre ces deux estimations."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the risk factors for heart failure in hypertensive patients seen in general practice. Compare the physician's estimates of the risk of heart failure and overall cardiovascular risk versus the risk calculated by validated scales. Evaluate the concordance between these two estimates."
        }
      ],
