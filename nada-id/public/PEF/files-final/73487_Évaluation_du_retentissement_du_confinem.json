        "titl": [
          {
            "lang": "fr",
            "value": "Évaluation du retentissement du confinement et déconfinement sur la prise en charge des patients atteints de maladies inflammatoires et dysimmunitaires suivis dans le cadre du FHU IMMINeNT (rhumatologie, dermatologie, médecine interne, pneumologie, gastro-entérologie et neurologie)"
          },
          {
            "lang": "en",
            "value": "Evaluation of the impact of the lockdown and easing of restrictions on the management of patients with inflammatory disease and immune disorders followed up as part of the FHU IMMINeNT project (rheumatology, dermatology, internal medicine, pulmonology, gastroenterology and neurology)"
          }
        ],
