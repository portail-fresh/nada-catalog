    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "évaluer la prévalence actuelle des comorbidités addictives chez des sujets dépendants aux opiacés, bénéficiant d’un traitement de substitution aux opiacés (TSO) depuis au moins 6 mois."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "assess the current prevalence of addictive comorbidities in opioid-dependent subjects who have been receiving opioid substitution therapy (OST) for at least 6 months."
        }
      ],
