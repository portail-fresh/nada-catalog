    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Le but de la présente étude était d'évaluer la prévalence et la gravité du syndrome de l'intestin irritable chez des patients avec une obésité morbide avant la chirurgie bariatrique."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The purpose of this study was to assess the prevalence and severity of irritable bowel syndrome in patients with morbid obesity prior to bariatric surgery."
        }
      ],
