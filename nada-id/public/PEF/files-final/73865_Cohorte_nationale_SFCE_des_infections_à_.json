    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire la présentation et l’évolution clinique de l’infection à SARS-CoV-2 chez les patients suivis en onco-hématologie pédiatrique ou en unité AJA d’un centre SFCE pour un cancer ou une tumeur bénigne traitée par chimiothérapie, radiothérapie ou thérapie ciblée."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Describe the presentation and clinical course of SARS-CoV-2 infection among patients followed up in a paediatric oncology-haematology department or young adult and adolescent unit at an SFCE centre, for cancer or a benign tumour treated with chemotherapy, radiotherapy or targeted therapy."
        }
      ],
