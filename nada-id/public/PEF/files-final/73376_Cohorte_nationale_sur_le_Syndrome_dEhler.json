    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif principal de cette étude est de décrire l’évolution naturelle du syndrome d’Ehlers-Danlos vasculaire, en particulier l’ordre d’apparition des différents types de complications (artérielles, digestives, pulmonaires et utérines)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective of this study is to describe the natural course of vascular Ehlers-Danlos syndrome, in particular the order of appearance of different types of complications (arterial, digestive, pulmonary and uterine)."
        }
      ],
