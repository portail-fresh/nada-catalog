    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Établir un panorama de la pratique médicale vis-à-vis de patients de 80 ans et plus hospitalisés dans des unités de cardiologie pour fibrillation auriculaire, cardiopathie coronarienne ou insuffisance cardiaque, et sa relation avec la comorbidité."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To provide a broad picture of medical practice in patients aged 80 years and over and hospitalised in a cardiology unit for atrial fibrillation, coronary heart disease or heart failure, and its relationship with comorbidity."
        }
      ],
