    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Trois objectifs : mesurer le nombre des personnes handicapées ou dépendantes ; évaluer les flux d'entrée et de sortie en incapacité ; relever la nature, la quantité, et les fournisseurs d'aides existantes, ainsi que les besoins non satisfaits"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Three objectives: to measure the number of handicapped or dependent people; to evaluate the flows in and out of disability; to highlight the nature, quantity and providers of existing aid, as well as unmet needs"
        }
      ],
