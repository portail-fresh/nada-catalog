    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Disposer pour l'ichtyose héréditaire d’une base de données exploitables sur laquelle pourront s’appuyer des projets de recherche ultérieurs ; tant épidémiologiques, cliniques (suivi de l’évolution de la maladie et de la survenue de complications) que physiopathologiques ou thérapeutiques."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To form a usable database for hereditary ichthyosis on which to base future research projects, such as epidemiological, clinical (disease progression follow-up and onset of complications) physiopathological or therapeutic projects."
        }
      ],
