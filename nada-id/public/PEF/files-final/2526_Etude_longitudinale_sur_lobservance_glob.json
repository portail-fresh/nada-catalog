    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer avec une précision suffisante le taux d’observance globale au traitement sur une période maximale de trois ans. L'étude est réalisée à la demande des autorités."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate with sufficient precision the overall observance rate for the treatment over a maximum period of three years. The study is carried out at the request of the authorities."
        }
      ],
