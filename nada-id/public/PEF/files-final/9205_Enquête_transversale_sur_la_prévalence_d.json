    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Estimer la prévalence des douleurs chroniques et neuropathiques chez des personnes atteintes de diabète de type 1 et 2. Évaluer la relation entre les douleurs neuropathiques et les douleurs polyneuropahties."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To estimate the prevalence of chronic and neuropathic pain in patients with type 1 or 2 diabetes. To assess the relationship between neuropathic and polyneuropathic pain."
        }
      ],
