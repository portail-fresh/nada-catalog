    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif de l’étude pharmaco-épidémiologique ESPASS est d’évaluer l’impact à 6 mois du changement ou de l’instauration du traitement antipsychotique principal sur l’autonomie sociale de patients souffrant de schizophrénie en fonction du parcours d’autonomisation éventuellement mis en place.t."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objective of the ESPASS pharmacoepidemiological study is to evaluate the impact at 6 months of the change or the introduction of the main antipsychotic treatment on the social autonomy of patients with schizophrenia according to the possible pathway to autonomy put in place."
        }
      ],
