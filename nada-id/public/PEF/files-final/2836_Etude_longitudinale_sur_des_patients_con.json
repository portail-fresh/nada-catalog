    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Les objectifs de l’étude étaient de décrire les modalités de prise en charge des EABC en conditions réelles de prescription et d’évaluer l’efficacité en situation réelle des stratégies thérapeutiques utilisées."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The study objectives were to describe how the management of AECB in real-life conditions of prescription and to assess the effectiveness of the therapeutic strategies used."
        }
      ],
