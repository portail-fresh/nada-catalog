    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Description de la population des résidents en EHPAD en France, en particulier description quantitative et qualitative des flux d'entrée et de sortie des résidents, notamment à l'hôpital."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe the population of nursing home residents in France and in particular to quantify transitions into or out of the nursing home and to describe the characteristics of the nursing home residents at admission and discharge."
        }
      ],
