    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Identifier les facteurs socio-démographiques, cliniques, psychocomportementaux et thérapeutiques explicatifs du non-contrôle tensionnel dans une population d'hypertendus suivis en pratique ambulatoire."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Identify the socio-demographic, clinic, psycho-behavioral and therapeutic factors that explain the absence of control of blood pressure in a population of hypertensives followed in an ambulatory manner."
        }
      ],
