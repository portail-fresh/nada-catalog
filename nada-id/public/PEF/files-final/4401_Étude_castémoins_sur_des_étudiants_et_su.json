    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Préciser les propriétés psychométriques (validité, fidélité) de la version française de la EETP et, d’autre part, confirmer le déficit en plaisir anticipatoire chez les sujets schizophrènes par rapport aux sujets sains."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To clarify the psychometric properties (validity, fidelity) of the French version of the TEPS and to confirm the deficit in schizophrenic subjects in relation to healthy subjects."
        }
      ],
