    "dataTypes": {
      "clinicalDataDetails": [
        {
          "lang": "fr",
          "value": "18-item TEPS, 61-item revised Physical Scale (PAS), 41-item Social Anhedonia Scale (SAS), 14-item Snaith Hamilton Pleasure Scale (SHAPS), 21-item Beck Depression Inventory-II (BDI-II)Echelles PAS anticipatory (PAS-ANT), PAS consummatory (PAS-CONS) pour le groupe témoin d'étudiants"
        },
        {
          "lang": "en",
          "value": "18-item TEPS, 61-item revised Physical Scale (PAS); 41-item Social Anhedonia Scale (SAS); 14-item Snaith Hamilton Pleasure Scale (SHAPS); 21-item Beck Depression Inventory-II (BDI-II); Anticipatory PAS (PAS-ANT) and PAS consummatory (PAS-CONS) scales for student control groups."
        }
      ],
      "isDataInBiobank": false
    },
    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "L’ensemble des sujets remplissait les questionnaires suivants quelques jours avant la sortie pour les patients hospitalisés ou en fin de consultation pour les patients ambulatoires."
        },
