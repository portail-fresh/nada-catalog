    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif général : Caractériser la perte osseuse en fonction de l'âge, évaluée de façon prospective, chez les hommes à differents sites du squelette. Identifier les déterminants cliniques, biochimiques et hormonaux de la perte osseuse et des fractures a l'aide des marqueurs biochimiques."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "General objective: A prospective evaluation characterising age-related bone loss in men at different skeletal sites. Identification of clinical, biochemical and hormonal determinants of bone loss and fractures with the aid of biochemical markers."
        }
      ],
