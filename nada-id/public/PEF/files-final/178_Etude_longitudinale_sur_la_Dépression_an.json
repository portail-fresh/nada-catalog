    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer l’évolution à 3 mois du niveau de Handicap personnel, professionnel et social par l’échelle de Sheehan, des patients présentant l’une des cinq pathologies psychiatriques suivantes : épisode dépressif majeur c'est-à-dire caractérisé, trouble anxiété généralisée, trouble anxiété sociale, trouble panique avec ou sans agoraphobie et troubles obsessionnels compulsifs, et pour laquelle un nouveau traitement par antidépresseur vient d’être initié."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To evaluate the change in self-reported personal, professional and social disability in patients with anxious or mood disorders three months after initiating antidepressant treatment."
        }
      ],
