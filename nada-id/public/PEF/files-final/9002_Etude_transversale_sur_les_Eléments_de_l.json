      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire la distribution des motifs de consultation et procédures de soins associés aux principaux problèmes de santé (résultats de consultation) pris en charge en médecine générale en France."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe the distribution of the reasons for encounter and processes of care associated to the main health problems (consultation results) managed in French general practice"
