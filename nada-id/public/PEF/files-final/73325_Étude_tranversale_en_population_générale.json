    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Fournir des indicateurs des besoins en santé mentale basés sur les indicateurs sociaux afin de permettre une meilleure planification en fonction des besoins d’un « bassin de population »"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Provide indicators of mental health needs based on social indicators to enable better planning based on the needs of a \"population pool\""
        }
      ],
