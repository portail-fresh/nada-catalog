    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "- Surveiller la consommation des substances psychoactives par des sujets présentant une pharmacodépendance - Décrire les caractéristiques des patients concernés - Évaluer le potentiel d’abus et de dépendance des médicaments"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Monitor the consumption of psychoactive substances by subjects with drug dependence Describe the characteristics of the patients concerned Assess the potential for drug abuse and dependence"
        }
      ],
