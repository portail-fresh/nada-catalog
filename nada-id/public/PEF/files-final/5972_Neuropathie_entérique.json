        "respRate": [
          {
            "lang": "fr",
            "value": "100 patients atteints de MICI et 30 patients atteints de MP ont été inclus dans la bio-collection. Ces patients font partie d’une cohorte historique. Les données phénotypiques sont à renseigner dans la base de données informatisée."
          },
          {
            "lang": "en",
            "value": "100 IBD patients and 30 PD patients were included in the biological collection. These patients are part of the historical cohort. Phenotypic data is entered in the electronic database."
          }
        ]
      }
