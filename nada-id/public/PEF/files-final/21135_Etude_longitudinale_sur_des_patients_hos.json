    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Démontrer l'influence des tempéraments sur l’expression de la manie ; notamment un lien entre la manie mixte et le tempérament dépressif."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To demonstrate the influence of temperament on the expression of mania; particularly the link between mixed mania and depressive temperament."
        }
      ],
