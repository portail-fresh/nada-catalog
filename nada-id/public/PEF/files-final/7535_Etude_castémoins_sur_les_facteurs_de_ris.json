    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Mettre en évidence les facteurs environnementaux et génétiques qui pourraient contribuer à la survenue du cancer différencié de la thyroïde chez l'enfant et le sujet jeune. Étudier les conséquences potentielles de l'accident de Tchernobyl."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To highlight genetic and environmental factors that contribute to the onset of differentiated thyroid cancer in children and young adults. To study the potential consequences of the Chernobyl accident."
        }
      ],
