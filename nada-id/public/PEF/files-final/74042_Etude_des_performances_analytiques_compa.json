        "titl": [
          {
            "lang": "fr",
            "value": "Etude des performances analytiques comparées d'un nouveau kit de détection moléculaire du COVID-19 rapides (Loop-Xplore) en ambulatoire (mode non-expert, bas débit - point of care) et en laboratoire de virologie (mode expert, haut débit, diagnostic médical)."
          },
          {
            "lang": "en",
            "value": "Study of the comparative analytical performance of a new COVID-19 rapid molecular detection kit (Loop-Xplore) in the outpatient setting (non-expert mode, low throughput - point of care) and in the virology laboratory (expert mode, high throughput, medical diagnosis)."
          }
        ],
