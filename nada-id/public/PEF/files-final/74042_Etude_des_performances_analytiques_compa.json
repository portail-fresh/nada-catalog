    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer la concordance entre l'outil de détection moléculaire rapide du virus SARS-CoV-2 (technique Loop-Xplore) dans les prélèvements nasopharyngés et salivaires en ambulatoire et la technique PCR de référence réalisée au laboratoire de virologie du CHU de Caen."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the concordance between the rapid molecular detection tool for SARS-CoV-2 (Loop-Xplore technique) in nasopharyngeal and salivary samples taken on an outpatient basis and the reference PCR technique performed in the virology laboratory at Caen University Hospital."
        }
      ],
