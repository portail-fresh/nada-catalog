    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif général : évaluer si les facteurs psychiatriques, addictologiques et psychologiques mesurés en liste d'attente ont un impact sur le pronostic médico-chirurgical des greffes de foie et de rein. Objectif secondaire : évaluer si les facteurs psychiatriques, addictologiques et psychologiques mesurés apres la greffe ont un impact sur le pronostic médico-chirurgical des greffes de foie et de rein"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "General objective: to evaluate whether psychiatric, addictive and psychological factors reported on waiting lists have an impact on medico-surgical outcome for liver and kidney transplantations. Secondary objective: to evaluate whether psychiatric, addictive and psychological factors reported after transplant have an impact on medico-surgical outcome for liver and kidney transplantations."
        }
      ],
