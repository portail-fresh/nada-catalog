    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif général : évaluer la pertinence de nouveaux biomarqueurs dans le suivi de l'aspergillose broncho pulmonaire allergique hors mucoviscidose (étude des variations du NO exhalé, de l’expectoration induite, de la sérologie aspergillaire par méthode ELISA, populations lymphocytaires)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the relevance of new biomarkers for monitoring allergic bronchopulmonary aspergillosis : study of changes in exhaled NO, induced sputum cellularity, Aspergillus serology by ELISA method lymphocyte populations."
        }
      ],
