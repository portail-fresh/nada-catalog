    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Mesurer la prévalence du tabagisme en France, identifier le profil type des fumeurs,"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Estimate smoking prevalence in France, identify smokers profiles according to their perceptions, attitudes and behaviour in relation to smoking cessation, determine predictive factors of quit attempts and assess tobacco-related behaviours and their evolutions according to the changes in the smokers' environments."
        }
      ],
