    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Les objectifs de l'étude SMILE étaient d'évaluer l'anxiété, le stress, la dépression, l'impact fonctionnel et les comportements d'adaptation chez les patients migraineux consultant en en médecine de ville en France"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objectives of the SMILE study were to assess anxiety, stress, depression, functional impact and adaptive behaviour in migraine patients with appointments in private practices in France."
        }
      ],
