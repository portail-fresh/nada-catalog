    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif principal de l'étude est d'évaluer les valeurs prédictives (PV) de trois tests cognitifs pour le diagnostic des troubles de la mémoire, de l'équilibre et des troubles liés aux personnes âgées vivant. L'objectif secondaire est d'évaluer la relation entre les chutes et les troubles cognitifs."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main aim of the study is to assess the predictive values (PV) of three tests for diagnosing mild cognitive impairments, balance and disorders in elderly individuals who are alive. The secondary aim is the assess the relationship between falls and cognitive impairment."
        }
      ],
