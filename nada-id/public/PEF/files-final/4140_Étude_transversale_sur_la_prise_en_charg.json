    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer l'impact, la pertinence et l'efficacité du réseau RPSM 78 Objectif du réseau : améliorer l’offre de soin en santé mentale par l’amélioration de la coordination entre les acteurs intervenant en santé mentale dans le territoire."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To evaluate the impact, the suitability and the efficacy of the RPSM 78 network Purpose of the network: to improve the provision of mental health care by improving the coordination between the actors involved in mental health across the country."
        }
      ],
