    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Identifier les facteurs de risques environnementaux et génétiques de survenue du cancer de la prostate et d’évaluer l’impact de l’exposition au chlordécone dans la survenue de la maladie."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To identify the environmental and genetic risk factors of prostate cancer and to assess the impact of chlordecone exposure in the onset of the disease."
        }
      ],
