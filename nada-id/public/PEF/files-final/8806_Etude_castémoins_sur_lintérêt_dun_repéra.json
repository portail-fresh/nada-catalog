    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer l’intérêt d’un repérage systématique des cas de démences effectué dans le cadre de RCP (Réunion de concertation pluridisciplinaire) en EHPAD (Établissement d'hébergement pour personnes âgées dépendantes)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To assess the relevance of systematically tracking dementia cases in EHPADs (institutions for dependent elderly people) within multidisciplinary team meetings."
        }
      ],
