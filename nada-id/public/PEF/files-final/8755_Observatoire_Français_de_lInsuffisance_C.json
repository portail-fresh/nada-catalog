    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire la démographie, les caractéristiques cliniques et les pratiques concernant la prise en charge diagnostique et thérapeutique des patients admis pour insuffisance cardiaque aiguë et des patients insuffisants cardiaques chroniques ambulatoires, en France."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe the demographic, clinical characteristics and practices regarding diagnostic and therapeutic treatment for patients admitted for acute heart failure and ambulatory patients with chronic heart failure in France."
        }
      ],
