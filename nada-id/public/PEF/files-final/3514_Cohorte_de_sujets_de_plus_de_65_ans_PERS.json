    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Étudier le vieillissement cérébral et fonctionnel après 65 ans, en distinguer les modalités normales et pathologiques, et identifier les sujets à haut risque de détérioration physique ou intellectuelle chez lesquels une action préventive serait possible."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Study brain and functional ageing after 65 years old, distinguish normal and pathological modalities, and identify physical or intellectual deterioration high-risk individuals, in order to plan a preventive action."
        }
      ],
