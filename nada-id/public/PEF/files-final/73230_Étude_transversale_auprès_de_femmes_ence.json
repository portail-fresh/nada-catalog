    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif de cette étude était de mesurer les expositions prénatales et postnatales au tabac, d’évaluer les perceptions et les connaissances des femmes et d’identifier les facteurs de risque."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objective of this study was to measure prenatal and postnatal tobacco exposure, assess women's perceptions and knowledge and identify risk factors."
        }
      ],
