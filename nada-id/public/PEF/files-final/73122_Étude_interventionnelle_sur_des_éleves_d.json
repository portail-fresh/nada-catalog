    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif est d’évaluer l’efficacité d’une action visant à lutter contre la sédentarité et à promouvoir l’activité physique sous toutes ses formes pour diminuer le risque cardiovasculaire et agir sur la corpulence"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objective is to evaluate the effectiveness of an intervention aimed at reducing sedentary behavior and promoting physical activity in all its forms, in order to lower cardiovascular risk and influence body composition."
        }
      ],
