    "dataTypes": {
      "clinicalDataDetails": {
        "lang": "fr",
        "value": "Examen clinique à l’inclusion et au cours du suivi tous les 2 ans : 1. Poids du patient ;2. Score de karnofsky ;3. Recherche de signes d'insuffisance hepatocellulaire: ascite clinique ;présence d'angiomes stellaires, encéphalopathie ;4. Recherche d'une hépatomégalie et/ou d'une splénomégalie ;5. Consommation de tabac ;6. Consommation d'alcool ;7. Toxicomanie."
      },
      "biologicalDataDetails": [
        {
          "lang": "fr",
          "value": "NFS-plaquettes, TP, facteur V, bilan hépatique usuel (ASAT, ALAT, PA, GGT), bilirubine totale, albumine, alpha foetoproteine"
        },
        {
          "lang": "en",
          "value": "CBC-platelets, TP, factor V, normal liver chemistry (ASAT, ALAT, PA, GGT), total bilirubin, albumin, alpha fetoprotein"
        }
      ],
