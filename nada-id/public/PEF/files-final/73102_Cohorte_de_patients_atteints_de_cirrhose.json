    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire l'évolution des patients atteints de cirrhose virale B et/ou C compensée. Objectifs secondaires : 1) Identifier les facteurs prédictifs de la survenue des complications cliniques de la cirrhose virale (décompensation; carcinome hépato-cellulaire) 2) Identifier les facteurs pronostiques de la survie."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Description of the natural history of HBV and/or HCV compensated cirrhosis."
        }
      ],
