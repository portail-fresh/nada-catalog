    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer l'incidence et la prévalence des cardiopathies ischémiques (CI) dans une population française, et de quantifier le risque associé à divers facteurs de risque"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To determine the incidence and prevalence of ischaemic cardiomyopathy (IC) among the French population and to quantify the risk associated with various risk factors."
        }
      ],
