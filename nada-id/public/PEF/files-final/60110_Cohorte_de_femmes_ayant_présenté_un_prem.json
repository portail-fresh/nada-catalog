    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif général : évaluer l'impact de différents modes de contraception hormonale ou non sur le risque de récidive de thrombose veineuse chez des femmes à haut risque thrombotique veineux."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "General objective: to study whether or not different forms of hormonal contraception contribute to the risk of venous thrombosis recurrence for women at high risk of venous thromboembolism."
        }
      ],
