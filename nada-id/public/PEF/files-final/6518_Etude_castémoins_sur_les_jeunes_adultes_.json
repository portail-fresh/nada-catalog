    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Étudier la transition vers l'âge adulte et le devenir des jeunes infectés par le VIH-1 ou -2 pendant l'enfance, principalement par voie verticale."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To study the outcome and transition to adulthood for young people infected by the HIV-1 or -2 virus during childhood, principally by vertical transmission."
        }
      ],
