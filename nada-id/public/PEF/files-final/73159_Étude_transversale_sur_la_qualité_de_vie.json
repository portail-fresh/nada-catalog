    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer la qualité de vie liée à la santé en France de sujets de 65ans et plus vivant à domicile, à l’aide d’une échelle auto-administrée spécifique validée en français, la LEIPAD."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the quality of life related to the health of subjects aged 65 years and over in France living at home, using a specific self-administered scale validated in French, the LEIPAD."
        }
