    "dataTypes": {
      "clinicalDataDetails": {
        "lang": "fr",
        "value": "Sexe, âge, poids, localisation de la tumeur, présence de métastases, osseuses et/ou viscérales, créatininémie,hémoglobinémie et clairance de la créatinine ou débit de filtration glomérulaire mesuré ou estimé."
      },
      "isDataInBiobank": false
    },
    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "Les données ont été recueillies sur 2 périodes de 15 jours consécutifs. La fonction rénale a été évaluée à l’aide de la formule de Cockcroft et de Gault qui estime la clairance de la créatinine (ClCr) et la formule “abrégée”, ou “simplifiée” MDRD (aMDRD, du nom de l’étude dont elle a été tirée Modification of Diet in Renal Disease ) qui permet une estimation du débit de filtration glomérulaire (DFG)."
        },
        {
          "lang": "en",
          "value": "Data collected over 2 periods of 15 consecutive days. Renal function is calculated using Cockcroft-Gault to assess the creatinine clearance rate (CICr) and an \"abbreviated\" or \"simplified\" Modification of Diet in Renal Disease (aMDRD) formulae to estimate glomerular filtration rate (GFR)."
        }
      ]
    },
