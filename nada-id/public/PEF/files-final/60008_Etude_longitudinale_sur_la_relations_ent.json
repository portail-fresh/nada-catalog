    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Analyser des interrelations entre les facteurs organisationnels, l’organisation du temps de travail et la santé des salariés des régions Nord-pas-de-calais/Picardie. Objectifs secondaires : - Référence régionale sur le niveau du stress au travail ; - Relation entre le stress au travail et la santé a l'instant t ; - Relation entre les incidences du stress et les incidences de problème de santé."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To analyse the relationship between organisational factors, working hours and employee health in the Nord-Pas-de-Calais/Picardie regions. Secondary objectives: - Regional reference on stress levels at work; - Relationship between occupational stress and health; - Relationship between incidences of stress and health problems."
        }
      ],
