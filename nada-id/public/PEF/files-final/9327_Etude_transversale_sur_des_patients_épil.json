    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer l'incidence globale des crises épileptiques dans la population de l'Ile et identifier le type clinique de crise et leurs facteurs."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To determine the overall incidence of epileptic seizures within the island population and to identify clinical seizure type and factors."
        }
