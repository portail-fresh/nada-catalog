    "dataTypes": {
      "clinicalDataDetails": [
        {
          "lang": "fr",
          "value": "Adolescent Depression Rating Scale : état émotionnel (sensation de bien être, épisodes dépressifs, perception de soi, pensées à propos de la mort,), manifestations autres (troubles du sommeil), interactions sociales à l'école, dans le travail et les loisirs, relations avec les autres"
        },
        {
          "lang": "en",
          "value": "Adolescent Depression Rating Scale: emotional state (sensation of well-being, depressive episodes, perception of self, thoughts about death), other manifestations (sleep problems), social interactions at school, at work and during leisure activities, relationships with others"
        }
      ],
      "isDataInBiobank": false
    },
    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "Pour les adolescents: the BDI 13-item version, the ADRSip (44 items). Pour les médecins: the ADRSic (11 items), the HDRS 17-item version [8,9] and the Clinical Global Impression Scale (CGI) severity scale [16] puis jugement clinique des patients (dépression, psycho-pathologie, DSM-IV)"
        },
        {
          "lang": "en",
          "value": "For adolescents: the BDI 13-item version, the ADRSip (44 items). For physicians: the ADRSic (11 items), the HDRS 17-item version [8,9] and the Clinical Global Impression (CGI) severity scale [16] and then clinical opinion of the patients (depression, mental illness, DSM-IV)"
        }
      ]
    },
    "geographicalCoverage": {
      "geoDetail": [
        {
          "lang": "fr",
          "value": "France, Belgique, Suisse"
        },
