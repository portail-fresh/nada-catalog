    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire l’expérience dépressive de l’adolescent et créer un outil de mesure de l’intensité dépressive destiné spécifiquement aux adolescents de 13 à 20 ans."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe the adolescent depression experience and create a tool for measuring the intensity of depression, intended specifically for adolescents from 13 to 20 years of age."
        }
      ],
