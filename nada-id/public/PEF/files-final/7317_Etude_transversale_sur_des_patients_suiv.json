    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer la façon dont les cardiologues prennent en charge le traitement médical des patients en fonction de leur fraction d'éjection du ventricule gauche après la sortie de l’hôpital."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Determine how cardiologists manage the medical treatment of patients based on their left ventricular ejection fraction after discharge from hospital."
        }
