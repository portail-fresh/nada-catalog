    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Proposer un accompagnement à la parentalité lors du retour à domicile des grands prématurés (inférieur à 33 SA: semaines d'aménorrhée), afin de prévenir et de prendre en charge les troubles du lien précoces et leur retentissement sur le devenir développemental des enfants."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To offer parental support when returning home with very premature babies (less than 33 weeks gestational age) in order to prevent and treat disorders related to premature birth and their impact on childhood development."
        }
      ],
