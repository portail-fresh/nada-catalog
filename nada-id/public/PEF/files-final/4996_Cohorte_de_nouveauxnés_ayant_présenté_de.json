    "dataTypes": {
      "clinicalDataDetails": [
        {
          "lang": "fr",
          "value": "examen clinique en pédiatrie (Le développement moteur, psychomoteur, cognitif, l’audition, la vue, le langage, la communication, le comportement à la maison, à l’école et en société, l’intégration et les apprentissages scolaires), facteurs de vulnérabilité, et spychologie, prise en charge en psychomotricité précoce, prise en charge en motricité (en cours), prise en charge précoce communication et langage, prise en charge de l’oralité"
        },
        {
          "lang": "en",
          "value": "Clinical examination in Paediatrics (development of motor and psychomotor skills; cognitive skills; hearing; sight; speech; communication skills; behaviour at home, in school and in the community; integration and academic learning); vulnerability and psychological factors; early psychomotor skills support; motor skills support (ongoing); early speech and communication support and oral communication support."
        }
      ],
