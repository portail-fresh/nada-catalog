    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Analyser les résultats de diagnostic de dépendance à l'alcool. Explorer les facteurs liés à l'évolution de la dépendance à l'alcool. Etudier les caractéristiques de la gestion des patients et leur gestion dans les soins primaires"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To analyse the diagnostic findings from alcohol addiction. To explore the factors related to the development of alcohol addiction. To examine the characteristics of patient management and management in primary healthcare."
        }
      ],
