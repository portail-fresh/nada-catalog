    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer les conséquences d’une ICD sur la qualité de vie des patients à travers l’évolution du profil EQ5D avant/pendant l’épisode"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Evaluate the consequences of a Clostridium difficile infection (CDI) on the quality of life of the patients through the progression of the EQ-5D profile before/during the episode"
        }
      ],
