    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif de cette étude transversale, conduite en France en 2012, était d’évaluer les modalités de dépistage et leur efficacité dans la reconnaissance de la maladie rénale chronique (MRC)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objective of this cross-sectional study, conducted in France in 2012, was to evaluate screening methods and their effectiveness in the recognition of chronic kidney disease (CKD)."
        }
      ],
