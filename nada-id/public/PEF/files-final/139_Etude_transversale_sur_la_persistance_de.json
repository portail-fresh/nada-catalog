    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire la persistance des thérapeutiques de prévention secondaire, entre 3 et 30 mois après hospitalisation pour un premier syndrome coronaire aigu (SCA), chez des patients suivis par des médecins généralistes."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Describe the persistence of secondary prevention therapeutics, between 3 and 30 months after hospitalization for a first acute coronary syndrome (ACS), in patients monitored by general practitioners"
