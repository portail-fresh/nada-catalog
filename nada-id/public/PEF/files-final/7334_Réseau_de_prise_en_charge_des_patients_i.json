    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Prévenir les hospitalisations itératives, améliore la qualité de vie des patients insuffisants cardiaques et optimiser le rapport qualité des soins/coût."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Reinforce patient education, improve compliance with medications and identify symptoms requiring treatment modification."
        }
