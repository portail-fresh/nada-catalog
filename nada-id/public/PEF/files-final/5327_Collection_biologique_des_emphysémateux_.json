      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Mise en place d’une collection biologique pour rechercher systématiquement la mutation génétique sous-jacente par séquençage du gène de l’alpha-1 antitrypsine."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Implementation of biological sample collection in order to systematically research the underlying genetic mutation by sequencing the alpha-1 antitrypsin gene."
        }
