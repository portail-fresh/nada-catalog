    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer le comportement des parents face à la fièvre de leur enfant et connaitre la concordance avec les recommandations courantes."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Study parents' knowledge and practices and their determinants in managing fever symptoms in children in France as compared with current recommendations."
        }
