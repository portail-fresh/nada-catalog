    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer l'action du post-conditionnement sur l'étendue de l'infarctus. Mesurer l'amélioration de la fonction contractile du myocarde grâce au post-conditionnement."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To determine the effect of postconditioning on the severity of the infarction To measure the improvement of the contractile function of the myocardium due to postconditioning."
        }
      ],
