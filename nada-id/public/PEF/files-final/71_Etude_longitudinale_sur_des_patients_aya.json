    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif principal : évaluer l'utilisation des ressources de santé et le coût dans les 12 mois suivant la réalisation d'une intervention coronarienne percutanée (ICP) associée à un traitement à visée antiplaquettaire chez un patient souffrant d'un syndrome coronarien aigu. Objectifs sécondaires : qualité de vie et évolution clinique."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Primary objective: evaluate the use of healthcare resources and cost in the 12 months following a percutaneous coronary intervention (PCI) combined with antiplatelet treatment in patients with acute coronary syndrome. Secondary objectives: quality of life and clinical evolution."
        }
      ],
