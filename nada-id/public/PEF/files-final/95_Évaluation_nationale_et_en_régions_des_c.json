    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire les stratégies de prise en charge du risque thromboembolique veineux (péri- et post-opératoire) chez les patients devant subir une intervention chirurgicale pour un cancer adbomino-pelvien."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Describe the strategies for caring for the risk of venous thromboembolism (peri- and postoperative) in patients who must undergo surgery for abdomino-pelvic cancer."
        }
      ],
