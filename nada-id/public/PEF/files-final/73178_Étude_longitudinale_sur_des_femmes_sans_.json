    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Les objectifs sont d'évaluer : 1) la valeur de dépistage des facteurs de risque de diabète gestationnel 2) la valeur pronostique des facteurs de risque pour les événements liés diabète gestationnel. L'étude permet également d'observer les changements dans la prévalence des facteurs de risque GDM"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The objectives are to evaluate: 1) the value of screening for risk factors for gestational diabetes 2) the prognostic value of risk factors for events related to gestational diabetes. The study also shows changes in the prevalence of GDM risk factors"
        }
      ],
