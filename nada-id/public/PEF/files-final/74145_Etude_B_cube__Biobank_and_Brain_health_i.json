    "dataTypes": {
      "clinicalDataDetails": {
        "lang": "fr",
        "value": "Antécédents médicaux et neurologiques; dépistage troubles moteurs et parkinsoniens; plaintes cognitive subjectives; bilan neuropsychologique complet : batterie de tests cognitifs (cliniques : MMSE, IST, FCSRT; 4 tests de la batterie informatisée CANTAB (Alzheimer); CDR-SOB; impression clinique; échelles de dépression et anxiété, etc."
      },
      "biologicalDataDetails": [
        {
          "lang": "fr",
          "value": "Biobanque complète : sang, urines (pool hebdomadaire de 6 prélèvements matin/soir), selles, salive, cheveux, ongles, prélèvement nasal."
        },
        {
          "lang": "en",
          "value": "Complete biobank: blood, urine (weekly pool of 6 morning/evening samples), stool, saliva, hair, nails, nasal swab."
        }
      ],
      "isDataInBiobank": true
    },
    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "Toutes les données sont recueillies par un enquêteur spécialisé en face à face ou par téléphone. Les données environnementales préalablement receuillies par autoquestionnaire (calendriers résidentiels et professionnels) sont systématiquement reprises et complétées par enquête téléphonique."
        },
        {
          "lang": "en",
          "value": "All data is collected by a specialised interviewer in person or by telephone. Environmental data previously collected by self-administered questionnaire (residential and professional calendars) is systematically reviewed and supplemented by telephone survey."
        }
      ]
    },
    "geographicalCoverage": {
