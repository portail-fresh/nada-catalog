      "qualityStatement": {
        "standardsCompliance": {},
        "otherQualityStatement": [
          {
            "lang": "fr",
            "value": "Présence d'une requête de cohérence au moment de la saisie des données informatiques et après la saisie des données informatiques.Gestion des données manquantes par retour vers un tiers.Autre(s) procédure(s) qualité : analyse des calendriers professionnels. Vérification de la cohérence des évaluations des expositions par croisement avec une matrice emploi exposition Les patients sont informés de l'utilisation de leur données."
          },
          {
            "lang": "en",
            "value": "Consistency request when entering computer data and after recording computer data. Missing data managed by returning to third party. Other quality procedure(s): analysis of work calenders. Exposure assessments are verified by cross-reference with an occupational exposure matrix. Patients are informed about the use of their data."
          }
        ]
      },
