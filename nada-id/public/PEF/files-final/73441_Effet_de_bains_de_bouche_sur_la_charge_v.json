    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire l’évolution de la charge virale nasale et salivaire chez des patients probablement infectés par le Covid-19, effectuant pendant 7 jours des bains de bouche avec et sans antiviraux."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Change from Baseline amount of SARS-CoV-2 in salivary samples at 7 days Quantitative PCR experiments will be performed and a quantitative analysis of the salivary samples will be made"
        }
      ],
