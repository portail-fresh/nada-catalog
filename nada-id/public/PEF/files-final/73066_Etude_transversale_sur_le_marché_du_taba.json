    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Fournir aux pouvoirs publics et aux professionnels concernés, dans un délai court, une première estimation fiable du phénomène, afin de pouvoir en mesurer l’impact dans le bilan de l’année 2013 du marché du tabac et des traitements pour l'arrêt du tabac."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To provide the public authorities and professionals concerned, within a short timeframe, with a first reliable estimate of the phenomenon, so as to be able to measure its impact in the 2013 review of the tobacco market and treatments for smoking cessation."
        }
      ],
