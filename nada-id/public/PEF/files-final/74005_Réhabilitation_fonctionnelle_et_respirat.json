    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer l’efficacité d’un parcours de soins multidisciplinaire personnalisé (comportant une réadaptation à l’effort, une réhabilitation respiratoire si nécessaire et une stratégie thérapeutique nutritionnelle) sur la qualité de vie (composante physique du SF-36) des patients atteints de la COVID-19."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Determine the efficacy of the individually tailored multidisciplinary healthcare path (including exercise rehabilitation, pulmonary rehabilitation, if necessary, and a nutritional therapeutic strategy) on quality of life (physical component of the SF-36) of patients with COVID-19."
        }
      ],
