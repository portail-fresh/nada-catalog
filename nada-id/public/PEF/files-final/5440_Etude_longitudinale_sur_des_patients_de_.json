    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "1- Caractériser la réponse immune à la vaccination grippale en fonction de la voie d'injection intramusculaire ou intradermique 2- Caractériser des marqueurs d'immunosenescence chez les populations non répondeuses à la vaccination grippale"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "1- To characterise immunity response to influenza vaccination in accordance with intradermal or intramuscular injection 2- To characterise immunosenescence markers in populations with no response to influenza vaccines"
        }
      ],
