    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire et comparer versus la pratique habituelle, l'impact à 6 mois d'une information délivrée par le pharmacien sur l'observance des traitements antidiabétiques oraux par les patients diabétiques de type II. Cette information sera délivrée au cours de 3 entretiens spécifiques."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe and compare the 6-month impact of pharmacist-delivered information on adherence to oral antidiabetic treatment by type II diabetic patients, compared with usual practice. This information will be delivered during 3 specific interviews."
        }
      ],
