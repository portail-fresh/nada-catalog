    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Disposer régulièrement de données sur la santé des enfants et des adolescents en vue d’éclairer l’action publique, en particulier sur la surcharge pondérale, l’asthme, la santé bucco dentaire."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Dispose regularly of children and adolescents health data to enlighten public action, in particular about overweight, asthma, oral health."
        }
      ],
