    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Suivre l’évolution des connaissances sur le VIH et le sida et les traitements antirétroviraux, des attitudes et des opinions à l’égard des personnes atteintes, de la perception de se contaminer par le virus, du recours au test de dépistage et de l’utilisation du préservatif."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To follow the evolution of knowledge concerning HIV and AIDS and antiretroviral treatment, attitudes and opinions with regard to infected persons, the perception of being contaminated by the virus, screening tests and condom use."
        }
      ],
