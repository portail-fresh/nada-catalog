    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire le taux d’infection grave à coronavirus dans les différents sous-groupes de patients porteurs de Néoplasies Myéloprolifératives définis par le traitement en cours lors de l’épidémie."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Describe the rate of serious Coronavirus infections in the different subgroups of patients with myeloproliferative neoplasms defined by ongoing treatment during the epidemic."
        }
      ],
