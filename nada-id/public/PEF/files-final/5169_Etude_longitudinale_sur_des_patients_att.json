    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Constituer une cohorte de patients atteints de troubles autistiques et bien évalués sur le plan clinique. Identifier des facteurs génétiques impliqués dans les troubles du spectre autistique. Etablir des corrélations génotype-phénotype."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To form a cohort of clinically well evaluated patients with autistic disorders. To identify genetic factors involved in autism spectrum disorders. To establish genotype-phenotype correlations."
        }
      ],
