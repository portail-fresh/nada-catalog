      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif principal est d'évaluer en vie réelle la manipulation des inhalateurs utilisés par des patients atteints de Bronchopneumopathie obstructive (BPCO)."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main objective is to evaluate the real life handling of inhalers used by patients with obstructive pulmonary disease (COPD)."
        }
