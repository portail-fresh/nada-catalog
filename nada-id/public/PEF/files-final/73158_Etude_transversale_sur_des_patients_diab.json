    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Cette étude à pour objectif d’utiliser le score EPICES (évaluation de la précarité et les inégalités dans les centres d'examens de santé ), afin de déterminer la relation entre le contrôle glycémique, les complications du diabète, et les conditions individuelles de privation"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The purpose of this study is to use the EPICES score (assessment of precariousness and inequalities in health examination centres) to determine the relationship between glycaemic control, complications of diabetes, and individual conditions of deprivation"
        }
      ],
