    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Démontrer la contamination des agriculteurs qui s'expose aux pesticides dans le traitement de la culture de champ plein. Déterminer le lien entre l'exposition aux pesticides pour un agriculteur avec la probabilité de développer un cancer."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To demonstrate the contamination of farmers who are exposed to pesticides while treating their outdoor agriculture. To determine the link between pesticide exposure for a farmer and the probability of developing cancer."
        }
      ],
