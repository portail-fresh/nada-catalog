    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire les marqueurs et facteurs de risque associés à l'insuffisance cardique chez les patients âgés de plus 70 ans suivis en ambulatoire. Evaluer les fonctions cognitives à l'aide de Memory Impairement Score et évaluer l'index pronostique de Senni."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Describe the markers and risk factors associated with cardiac insufficiency in patients aged over 70 years followed in ambulatory mode. Assess the cognitive functions using Memory Impairment Score and assess the Senni prognostic index."
        }
      ],
