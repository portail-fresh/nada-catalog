    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif principal de RéAC est d’améliorer les conditions de prise en charge des victimes d’arrêts cardiaques et ainsi améliorer les chances de survie des patients."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The main aim of RéAC is to improve the treatment conditions for cardiac arrest victims, as well as improve the chances of survival for patients."
        }
      ],
