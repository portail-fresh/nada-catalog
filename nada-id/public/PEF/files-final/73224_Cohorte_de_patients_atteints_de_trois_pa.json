    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Dans les trois groupes, le but fut d’évaluer la différence entre une prise en charge classique et une prise en charge homéopathique"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The aim of these three groups was to assess the difference between conventional and homoeopathic treatment."
        }
      ],
