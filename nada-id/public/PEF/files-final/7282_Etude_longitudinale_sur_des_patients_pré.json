    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Valider la valeur diagnostique du scanner coronaire multicoupe dans une population de patients stables ressentant des douleurs thoraciques évoquant une coronaropathie et chez lesquels une coronarographie est nécessaire."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To validate the diagnostic value of the multislice coronary CT scan in a population of stable patients experiencing chest pain suggestive of coronary artery disease and for whom a coronary angiography is necessary."
        }
      ],
