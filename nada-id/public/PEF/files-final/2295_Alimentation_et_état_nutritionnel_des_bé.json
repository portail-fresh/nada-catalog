    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire les profils sociodémographiques et économiques, les habitudes alimentaires (approvisionnements alimentaires, recours à l’aide alimentaire et fréquence de consommation) et l’état nutritionnel des personnes ayant recours à l’aide alimentaire en 2004-2005 et en 2011-2012."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe sociodemographic and economic profiles, dietary habits (food supplies, food aid use and frequency of consumption) and nutritional status of food aid users in 2004-2005 and 2011-2012."
        }
      ],
