    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Étudier les caractéristiques cliniques et biologiques, ainsi que les facteurs de risque cardiovasculaire, chez des hommes et des femmes porteurs du syndrome métabolique."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Study clinical and biological characteristics, as well as cardiovascular risk factors, in men and women with metabolic syndrome."
        }
      ],
