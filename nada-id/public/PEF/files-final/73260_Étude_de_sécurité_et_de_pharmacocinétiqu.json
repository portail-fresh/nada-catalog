    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif principal de l'étude est de vérifier l'absence d'accumulation de bismuth chez les sujets à qui l'on a prescrit Pylera®, par une approche pharmacocinétique en vie réelle."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The primary objective of the study is to verify the absence of accumulation of bismuth in subjects prescribed Pylera®, a pharmacokinetic approach in a real-life setting."
        }
      ],
