    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Comparer le taux d'hospitalisation pour bronchiolite à VRS entre des enfants prématurés nés à <= 32 semaines d'âge gestationnel sans dysplasie broncho-pulmonaire (DBP) et des enfants nés à terme, suivis pendant la saison de VRS 2008-2009"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Compare the rate of hospitalization for bronchiolitis to RSV between premature children born <= 32 weeks of gestational age without bronchopulmonary dysplasia (BPD) and full-term children, during the 2008-2009 RSV season"
        }
