    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire et comparer le fardeau des infections respiratoires aiguës (IRA) liées au virus de la grippe, en termes de morbidité et de consommation médicale, selon le statut vaccinal, chez les 65 ans et plus consultant spontanément en médecine générale"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Describe and compare the burden of acute respiratory infections (IRA) linked to influenza virus, in terms of morbidity and medical consumption, according to the vaccinal status, in those 65 years and older spontaneously consulting in general practice"
        }
      ],
