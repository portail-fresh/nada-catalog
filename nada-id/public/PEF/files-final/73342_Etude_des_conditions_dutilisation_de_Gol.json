    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer le maintien du traitement par golimumab 24 mois après la prescription initiale chez des patients adultes atteints d'un rhumatisme inflammatoire chronique, en pratique clinique en France Le critère principal est le pourcentage total de patients ayant maintenu le traitement par golimumab deux ans après la prescription initiale."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To evaluate the maintenance of golimumab therapy 24 months after initial prescription in adult patients with chronic inflammatory rheumatism in clinical practice in France The primary endpoint is the total percentage of patients who maintained treatment with golimumab two years after the initial prescription."
        }
      ],
