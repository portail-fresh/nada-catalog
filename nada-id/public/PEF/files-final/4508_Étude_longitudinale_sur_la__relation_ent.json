    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Utiliser l'EMA (Evaluation Ecologique Momentanée) pour tester la relation entre le temps de réaction et le craving pendant la désintoxication alcoolique. Décrire l'intensité, la fréquence et les facteurs prédictifs de craving, avec un enregistrement simultané d'autres états affectifs."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To use the Ecological Momentary Assessment (EMA) to test the relationship between reaction times and cravings during alcohol detoxification. To describe the intensity, frequency and predictive factors of cravings, while also recording other emotional states."
        }
      ],
