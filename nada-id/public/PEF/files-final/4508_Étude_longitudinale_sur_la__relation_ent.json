    "dataTypes": {
      "clinicalDataDetails": [
        {
          "lang": "fr",
          "value": "état clinique, le diagnostic psychiatrique et somatique, antécédents d'alcoolisme avec le nombre de processus passés de désintoxication, la consommation de tabac, traitement. Évaluation du craving (Obsessive Craving Drinking Scale), de la dépression et de l'anxiété (Beck Depression Inventory and Symptom Check list)"
        },
        {
          "lang": "en",
          "value": "clinical state, the psychiatric and somatic diagnosis, history of alcoholism with the number of previous detoxification processes, tobacco consumption, treatment. Assessment of cravings (Obsessive Craving Drinking Scale), depression and anxiety (Beck Depression Inventory and Symptom Check list)"
        }
      ],
      "isDataInBiobank": false
    },
    "collectionProcess": {
      "collectionModeDetails": [
        {
          "lang": "fr",
          "value": "Cette procédure comporte l’utilisation d’un ordinateur que les participants emportent avec eux et dans lequel ils peuvent enregistrer le craving soit au moment même où il survient soit immédiatement après. Ils y enregistrent leurs émotions, leurs sensations, les pensées concomitantes au moment précis où survient le craving. Les enregistrement se font 8 à 12 fois par jour durant les 3 semaines suivant la désintoxication.Un technicien vient récupérer les données une fois par semaine au domicile du patient. De plus, il vérifie la batterie de l'appareil d'enregistrement."
        },
        {
          "lang": "en",
          "value": "This procedure involves using a computer that the participants take with them and that they use to record cravings at the time that they arise or immediately afterward. They record their emotions, sensations, and concomitant thoughts at the precise moment that the craving arises. The records are saved 8 to 12 times per day for 3 weeks following detoxification. A technician comes to collect the data once per week at the patient's home. The technician also checks the battery of the registration device."
        }
      ]
    },
    "geographicalCoverage": {
      "geoDetail": [
        {
          "lang": "fr",
