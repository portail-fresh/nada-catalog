    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L’objectif de l'étude est de définir les caractéristiques épidémiologiques de la tuberculose affectant les sujets migrants et natifs en Guadeloupe."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The aim of the study was to define the epidemiological characteristics of tuberculosis affecting migrant and native subjects in Guadeloupe."
        }
