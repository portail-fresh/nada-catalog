    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer le profil des patients traités, l’adéquation des pratiques au RCP, l’observance, la tolérance et l’efficacité de la rosiglitazone."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe the profiles of patients being treated by general practitioners and specialists, compatibility of practice with the SPC, patient compliance, and the safety and efficacy of rosiglitazone in \"real-world\" conditions of use."
        }
      ],
