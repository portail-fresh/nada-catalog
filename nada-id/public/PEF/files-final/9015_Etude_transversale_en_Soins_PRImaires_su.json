    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Estimer en France l’incidence des événements indésirables associés aux soins (EIAS) évitables en médecine générale et d’en décrire la typologie."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To estimate the incidence of avoidable treatment-related adverse effects in general medicine and to describe the typology."
        }
      ],
