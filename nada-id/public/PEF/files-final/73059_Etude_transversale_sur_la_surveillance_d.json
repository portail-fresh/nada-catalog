    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Identifier les médicaments détournés à partir d’ordonnances modifiées ou falsifiées présentées en pharmacie d’officine. Elle permet aussi de classer les médicaments les plus détournés au niveau régional et national par rapport aux données de vente."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To identify medicines diverted using modified or falsified prescriptions presented at the pharmacy. It also allows for the classification of the most diverted medicines at the regional and national level in relation to the sales data."
        }
      ],
