    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Etudier la relation entre le nombre d’épisodes dépressifs antérieurs et le poids des événements de vie dans le déclenchement de l’épisode dépressif actuel"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To study the relationship between the number of previous depressive episodes and the impact of life events on the triggering of the current depressive episode"
        }
      ],
