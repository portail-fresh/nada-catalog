    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Etudier la mortalité des cancers dans une cohorte de travailleurs des entreprises contractantes du secteur nucléaire français. Objectif secondaire : cette étude vise à approfondir la connaissance des effets cancérigènes des faibles doses de rayonnement ionisant et les effets de poly-expositions."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To study cancer mortality in a cohort of French nuclear workers from contracting companies. Secondary objective: to improve knowledge of the carcinogenic effects of low-level doses of ionizing radiation and multiple exposure."
        }
      ],
