    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire les conditions d’utilisation du candésartan dans la prise en charge de l’insuffisance cardiaque, la fréquence des arrêts de traitement et leurs motifs et l’évolution des patients sous traitement"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe the way candesartan is used in heart failure treatment in France (treatment initiation and follow-up) treatment discontinuation occurences and reasons why and patients clinical evolution"
        }
      ],
