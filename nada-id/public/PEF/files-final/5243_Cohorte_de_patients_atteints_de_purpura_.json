    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Évaluer le profil biologique de patients en poussée cutanée de purpura rhumatoïde selon la présence ou non d'une atteinte rénale, identifier une susceptibilité génétique particulière et identifier des bio-marqueurs pouvant prédire l'évolution péjorative de l’atteinte rénale à 1 an."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To evaluate the biological profile of patients with skin Henoch-Schönlein purpura according to the presence or absence of renal impairment. To identify specific genetic susceptibility and biomarkers that can predict poor renal impairment prognosis at 1 year."
        }
      ],
