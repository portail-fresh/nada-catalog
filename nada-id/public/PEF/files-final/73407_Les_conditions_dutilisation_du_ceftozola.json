    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Décrire les caractéristiques sociodémographiques et cliniques ainsi que la prise en charge et les résultats cliniques des patients hospitalisés et traités par ceftolozane/tazobactam en pratique courante."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To describe the sociodemographic and clinical characteristics, management and clinical outcomes of hospitalized patients treated with ceftolozane/tazobactam in routine practice."
        }
      ],
