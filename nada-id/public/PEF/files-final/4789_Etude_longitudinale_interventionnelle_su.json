    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Déterminer les effets de l'augmentation des apports en acide docosahexaénoïque sur la fonction plaquettaire et le stress oxydant dans un groupe de volontaires sains de sexe masculin."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To determine the effects of increased intake of docosahexaenoic acid on platelet function and oxidative stress in a group of healthy male volunteers."
        }
      ],
