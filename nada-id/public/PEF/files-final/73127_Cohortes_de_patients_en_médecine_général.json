    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif est de réaliser une vaste cartographie des hypertendus suivis en médecine générale, axée sur le niveau de la pression pulsée"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The aim is to extensively map hypertensive patients monitored by general practitioners, focusing on level of pulse pressure."
        }
      ],
