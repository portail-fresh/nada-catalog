    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "L'objectif général est de fournir des données précises sur les femmes atteintes d'un cancer du sein. Ces données seront alors très utiles pour la mise en place d'études épidémiologiques"
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "The general objective is to provide data on women with breast cancer. These data will be very useful for developing epidemiological studies."
        }
      ],
