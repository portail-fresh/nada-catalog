    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Evaluer si la réalisation des tests urinaires de dépistage des toxiques au cabinet du médecin généraliste améliore la prise en charge des patients substitués."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To assess whether conducting urine-based toxicity screening tests in the general practitioner's surgery improves treatment for drug-substituted patients."
        }
      ],
