    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Étudier l'association possible entre la survenue de tumeur cérébrale et l'utilisation des nouveaux outils de communication et d'autres expositions environnementales."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "To investigate the potential link between the occurence of brain tumours and the use of new communication devices as well as other environmental exposures."
        }
      ],
