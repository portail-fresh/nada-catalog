    "stdyInfo": {
      "abstract": [
        {
          "contentType": "purpose",
          "lang": "fr",
          "value": "Objectif principal : Déterminer l’impact de la présence d’un Syndrome d’Apnée Obstructive du Sommeil (SAOS) sévère sur les résultats pondéraux de la chirurgie bariatrique."
        },
        {
          "contentType": "purpose",
          "lang": "en",
          "value": "Addressing the determinants of health prognosis in obese patients who benefit from bariatric surgery."
        }
      ],
