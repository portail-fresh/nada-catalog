      "clinicalDataDetails": [
        {
          "lang": "fr",
          "value": "Bilan d’allergie : tests allergologiques cutanés, examen standardisé de la peau de Williams (eczéma), test de course libre avec débit de pointe respiratoire (hyperréactivité bronchique)"
        },
        {
          "lang": "en",
          "value": "Allergy assessment: skin prick tests, Williams standardised skin test (eczema), free running test, with peak respiratory flow (bronchial hyper-reactivity)."
        }
      ],
